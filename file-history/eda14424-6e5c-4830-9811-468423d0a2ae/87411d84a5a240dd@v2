import json

path = '/var/www/velocms/composer.json'
with open(path) as f:
    data = json.load(f)

# Remove the generic VeloCMS\Modules\ mapping and replace with
# explicit per-module mappings that match lowercase directory names
psr4 = data['autoload']['psr-4']

if 'VeloCMS\\Modules\\' in psr4:
    del psr4['VeloCMS\\Modules\\']

# Add explicit module mappings
module_maps = {
    'VeloCMS\\Modules\\Pages\\':      'modules/pages/',
    'VeloCMS\\Modules\\Blog\\':       'modules/blog/',
    'VeloCMS\\Modules\\Media\\':      'modules/media/',
    'VeloCMS\\Modules\\Navigation\\': 'modules/navigation/',
    'VeloCMS\\Modules\\Users\\':      'modules/users/',
    'VeloCMS\\Modules\\Seo\\':        'modules/seo/',
    'VeloCMS\\Modules\\Search\\':     'modules/search/',
    'VeloCMS\\Modules\\Forms\\':      'modules/forms/',
    'VeloCMS\\Modules\\Settings\\':   'modules/settings/',
    'VeloCMS\\Modules\\Audit\\':      'modules/audit/',
    'VeloCMS\\Modules\\Api\\':        'modules/api/',
    'VeloCMS\\Modules\\Email\\':      'modules/email/',
    'VeloCMS\\Modules\\Cron\\':       'modules/cron/',
    'VeloCMS\\Modules\\Backup\\':     'modules/backup/',
}
psr4.update(module_maps)

with open(path, 'w') as f:
    json.dump(data, f, indent=4)

print('composer.json updated with explicit module mappings')
for k, v in module_maps.items():
    print(f'  {k} => {v}')
