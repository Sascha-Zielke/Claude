# Write all files
for rel_path, content in files.items():
    full_path = base + '/' + rel_path
    os.makedirs(os.path.dirname(full_path), exist_ok=True)
    with open(full_path, 'w') as f:
        f.write(content.lstrip('\n'))
    print('OK  ' + rel_path)

# Patch cli/velocms to add cron:run command
cli_path = base + '/cli/velocms'
cli = open(cli_path).read()

if 'cron:run' not in cli:
    cli = cli.replace(
        "'cache:clear'",
        "'cron:run'        => VeloCMS\\Cli\\CronRunCommand::class,\n    'cache:clear'"
    )
    open(cli_path, 'w').write(cli)
    print('OK  cli/velocms (cron:run added)')
else:
    print('OK  cli/velocms (cron:run already present)')

