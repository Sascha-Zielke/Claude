files['modules/cron/admin/controllers/CronAdminController.php'] = r"""<?php declare(strict_types=1);
namespace VeloCMS\Modules\Cron\Admin;

use VeloCMS\Admin\BaseController;
use VeloCMS\Core\Auth;
use VeloCMS\Core\Database;
use VeloCMS\Core\Request;
use VeloCMS\Core\Response;
use VeloCMS\Modules\Cron\Models\CronJob;

class CronAdminController extends BaseController
{
    public function index(Request $request, array $params): Response
    {
        $auth = $this->auth();
        $auth->requireLogin();

        $pdo  = $this->app->make(Database::class)->core();
        $jobs = (new CronJob($pdo))->all();

        return $this->layout('cron/index.php', [
            'user' => $auth->user(),
            'page' => 'cron',
            'jobs' => $jobs,
            'csrf' => $auth->csrfToken(),
        ]);
    }

    public function toggle(Request $request, array $params): Response
    {
        $auth = $this->auth();
        $auth->requireLogin();
        $auth->verifyCsrf();

        $pdo     = $this->app->make(Database::class)->core();
        $model   = new CronJob($pdo);
        $id      = (int) ($params['id'] ?? 0);
        $enabled = $request->post('enabled', '0') === '1';
        $model->toggle($id, $enabled);

        return $this->redirect('/admin/cron');
    }
}
"""

