files['modules/cron/models/CronJob.php'] = r"""<?php declare(strict_types=1);
namespace VeloCMS\Modules\Cron\Models;

class CronJob
{
    public function __construct(private readonly \PDO $pdo) {}

    public function all(): array
    {
        return $this->pdo->query(
            'SELECT * FROM cron_jobs ORDER BY name'
        )->fetchAll();
    }

    /** Returns jobs whose next_run_at is due and are enabled. */
    public function getDue(): array
    {
        return $this->pdo->query(
            "SELECT * FROM cron_jobs
             WHERE enabled = 1 AND next_run_at <= NOW()"
        )->fetchAll();
    }

    /** Mark a job as run and schedule next execution. */
    public function markRun(int $id, int $intervalMinutes): void
    {
        $this->pdo->prepare(
            'UPDATE cron_jobs
             SET last_run_at = NOW(),
                 next_run_at = DATE_ADD(NOW(), INTERVAL ? MINUTE)
             WHERE id = ?'
        )->execute([$intervalMinutes, $id]);
    }

    public function toggle(int $id, bool $enabled): void
    {
        $this->pdo->prepare(
            'UPDATE cron_jobs SET enabled = ? WHERE id = ?'
        )->execute([$enabled ? 1 : 0, $id]);
    }
}
"""

# ── cli/commands/CronRunCommand.php ───────────────────────────────────────────
files['cli/commands/CronRunCommand.php'] = r"""<?php declare(strict_types=1);
namespace VeloCMS\Cli;

use VeloCMS\Core\Application;
use VeloCMS\Core\Database;
use VeloCMS\Modules\Cron\Models\CronJob;

class CronRunCommand
{
    public function __construct(private readonly Application $app) {}

    public function run(array $args): void
    {
        $pdo  = $this->app->make(Database::class)->core();
        $jobs = new CronJob($pdo);

        $due = $jobs->getDue();
        if (empty($due)) {
            echo "No jobs due.\n";
            return;
        }

        foreach ($due as $job) {
            echo "Running: {$job['name']} ... ";
            try {
                $this->dispatch($job['name']);
                $jobs->markRun((int) $job['id'], (int) $job['interval_minutes']);
                echo "OK\n";
            } catch (\Throwable $e) {
                echo "FAILED: {$e->getMessage()}\n";
            }
        }
    }

    private function dispatch(string $name): void
    {
        $map = [
            'email:flush'    => EmailFlushCommand::class,
            'search:reindex' => SearchReindexCommand::class,
            'cache:clear'    => CacheClearCommand::class,
            'audit:prune'    => AuditPruneCommand::class,
        ];

        if (!isset($map[$name])) {
            throw new \RuntimeException("Unknown cron job: {$name}");
        }

        $cmd = new $map[$name]($this->app);
        $cmd->run([]);
    }
}
"""

