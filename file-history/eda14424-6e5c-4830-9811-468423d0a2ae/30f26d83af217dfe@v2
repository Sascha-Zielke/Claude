files['modules/blog/models/Post.php'] = r"""<?php declare(strict_types=1);
namespace VeloCMS\Modules\Blog\Models;

class Post
{
    public function __construct(private readonly \PDO $pdo) {}

    public function all(): array
    {
        return $this->pdo->query(
            "SELECT p.*, u.name AS author_name
             FROM posts p
             LEFT JOIN users u ON u.id = p.author_id
             WHERE p.deleted_at IS NULL
             ORDER BY p.created_at DESC"
        )->fetchAll();
    }

    public function published(int $limit = 10, int $offset = 0): array
    {
        $stmt = $this->pdo->prepare(
            "SELECT p.*, u.name AS author_name
             FROM posts p
             LEFT JOIN users u ON u.id = p.author_id
             WHERE p.deleted_at IS NULL AND p.status = 'published'
             ORDER BY p.published_at DESC
             LIMIT ? OFFSET ?"
        );
        $stmt->execute([$limit, $offset]);
        return $stmt->fetchAll();
    }

    public function findById(int $id): ?array
    {
        $stmt = $this->pdo->prepare(
            'SELECT * FROM posts WHERE id = ? AND deleted_at IS NULL LIMIT 1'
        );
        $stmt->execute([$id]);
        return $stmt->fetch() ?: null;
    }

    public function findBySlug(string $slug): ?array
    {
        $stmt = $this->pdo->prepare(
            "SELECT p.*, u.name AS author_name
             FROM posts p
             LEFT JOIN users u ON u.id = p.author_id
             WHERE p.slug = ? AND p.status = 'published' AND p.deleted_at IS NULL LIMIT 1"
        );
        $stmt->execute([$slug]);
        return $stmt->fetch() ?: null;
    }

    public function create(array $data, int $userId): int
    {
        $slug = $this->uniqueSlug($data['slug'] ?: $this->slugify($data['title']));
        $this->pdo->prepare(
            'INSERT INTO posts (title, slug, body, status, author_id, published_at)
             VALUES (?, ?, ?, ?, ?, ?)'
        )->execute([
            $data['title'],
            $slug,
            $data['body'],
            $data['status'],
            $userId,
            $data['status'] === 'published' ? date('Y-m-d H:i:s') : null,
        ]);
        $id = (int) $this->pdo->lastInsertId();
        $this->syncCategories($id, $data['categories'] ?? []);
        $this->syncTags($id, $data['tags'] ?? '');
        return $id;
    }

    public function update(int $id, array $data, int $userId): void
    {
        $slug = $this->uniqueSlug($data['slug'] ?: $this->slugify($data['title']), $id);
        $this->pdo->prepare(
            'UPDATE posts SET title=?, slug=?, body=?, status=?, published_at=? WHERE id=?'
        )->execute([
            $data['title'],
            $slug,
            $data['body'],
            $data['status'],
            $data['status'] === 'published' ? date('Y-m-d H:i:s') : null,
            $id,
        ]);
        $this->syncCategories($id, $data['categories'] ?? []);
        $this->syncTags($id, $data['tags'] ?? '');
    }

    public function softDelete(int $id): void
    {
        $this->pdo->prepare('UPDATE posts SET deleted_at = NOW() WHERE id = ?')->execute([$id]);
    }

    public function categoriesFor(int $postId): array
    {
        $stmt = $this->pdo->prepare(
            'SELECT c.* FROM categories c
             JOIN post_categories pc ON pc.category_id = c.id
             WHERE pc.post_id = ?'
        );
        $stmt->execute([$postId]);
        return $stmt->fetchAll();
    }

    public function tagsFor(int $postId): array
    {
        $stmt = $this->pdo->prepare(
            'SELECT t.* FROM tags t
             JOIN post_tags pt ON pt.tag_id = t.id
             WHERE pt.post_id = ?'
        );
        $stmt->execute([$postId]);
        return $stmt->fetchAll();
    }

    private function syncCategories(int $postId, array $categoryIds): void
    {
        $this->pdo->prepare('DELETE FROM post_categories WHERE post_id = ?')->execute([$postId]);
        foreach ($categoryIds as $catId) {
            $this->pdo->prepare(
                'INSERT IGNORE INTO post_categories (post_id, category_id) VALUES (?, ?)'
            )->execute([$postId, (int) $catId]);
        }
    }

    private function syncTags(int $postId, string $tagString): void
    {
        $this->pdo->prepare('DELETE FROM post_tags WHERE post_id = ?')->execute([$postId]);
        $names = array_filter(array_map('trim', explode(',', $tagString)));
        foreach ($names as $name) {
            $slug = $this->slugify($name);
            $this->pdo->prepare(
                'INSERT IGNORE INTO tags (name, slug) VALUES (?, ?)'
            )->execute([$name, $slug]);
            $tag = $this->pdo->prepare('SELECT id FROM tags WHERE slug = ? LIMIT 1');
            $tag->execute([$slug]);
            $tagId = $tag->fetchColumn();
            if ($tagId) {
                $this->pdo->prepare(
                    'INSERT IGNORE INTO post_tags (post_id, tag_id) VALUES (?, ?)'
                )->execute([$postId, $tagId]);
            }
        }
    }

    private function slugify(string $text): string
    {
        $text = mb_strtolower($text);
        $text = preg_replace('/[^a-z0-9\s-]/', '', $text) ?? $text;
        return trim(preg_replace('/[\s-]+/', '-', $text) ?? $text, '-');
    }

    private function uniqueSlug(string $slug, int $excludeId = 0): string
    {
        $original = $slug;
        $i = 1;
        while (true) {
            $stmt = $this->pdo->prepare(
                'SELECT id FROM posts WHERE slug = ? AND id != ? AND deleted_at IS NULL LIMIT 1'
            );
            $stmt->execute([$slug, $excludeId]);
            if (!$stmt->fetch()) break;
            $slug = $original . '-' . $i++;
        }
        return $slug;
    }
}
"""

