namespace VeloCMS\Modules\Blog\Admin;

use VeloCMS\Admin\BaseController;
use VeloCMS\Core\Database;
use VeloCMS\Core\Request;
use VeloCMS\Core\Response;
use VeloCMS\Modules\Blog\Models\Post;
use VeloCMS\Modules\Blog\Models\Category;

class PostAdminController extends BaseController
{
    private function postModel(): Post
    {
        return new Post($this->app->make(Database::class)->core());
    }

    private function categoryModel(): Category
    {
        return new Category($this->app->make(Database::class)->core());
    }

    public function index(Request $req, array $params): Response
    {
        $this->auth()->requireRole('superadmin', 'site-admin', 'editor', 'author');
        return $this->layout('blog/index.php', [
            'user'  => $this->auth()->user(),
            'page'  => 'blog',
            'posts' => $this->postModel()->all(),
        ]);
    }

    public function create(Request $req, array $params): Response
    {
        $this->auth()->requireRole('superadmin', 'site-admin', 'editor', 'author');
        return $this->layout('blog/form.php', [
            'user'       => $this->auth()->user(),
            'page'       => 'blog',
            'csrf'       => $this->auth()->csrfToken(),
            'title'      => 'New Post',
            'action'     => '/admin/blog',
            'record'     => null,
            'categories' => $this->categoryModel()->all(),
            'error'      => null,
        ]);
    }

    public function store(Request $req, array $params): Response
    {
        $this->auth()->requireRole('superadmin', 'site-admin', 'editor', 'author');
        if (!$this->auth()->verifyCsrf()) return $this->redirect('/admin/blog');
        $data = [
            'title'      => trim($req->post('title', '')),
            'slug'       => trim($req->post('slug', '')),
            'body'       => $req->post('body', ''),
            'status'     => $req->post('status', 'draft'),
            'categories' => $req->post('categories', []),
            'tags'       => trim($req->post('tags', '')),
        ];
        if ($data['title'] === '') {
            return $this->layout('blog/form.php', [
                'user'       => $this->auth()->user(),
                'page'       => 'blog',
                'csrf'       => $this->auth()->csrfToken(),
                'title'      => 'New Post',
                'action'     => '/admin/blog',
                'record'     => $data,
                'categories' => $this->categoryModel()->all(),
                'error'      => 'Title is required.',
            ]);
        }
        $this->postModel()->create($data, (int) $this->auth()->id());
        return $this->redirect('/admin/blog');
    }

    public function edit(Request $req, array $params): Response
    {
        $this->auth()->requireRole('superadmin', 'site-admin', 'editor', 'author');
        $record = $this->postModel()->findById((int) $params['id']);
        if (!$record) return $this->redirect('/admin/blog');
        $postCats = array_column($this->postModel()->categoriesFor((int)$params['id']), 'id');
        $postTags = implode(', ', array_column($this->postModel()->tagsFor((int)$params['id']), 'name'));
        return $this->layout('blog/form.php', [
            'user'       => $this->auth()->user(),
            'page'       => 'blog',
            'csrf'       => $this->auth()->csrfToken(),
            'title'      => 'Edit Post',
            'action'     => '/admin/blog/' . $params['id'],
            'record'     => $record,
            'postCats'   => $postCats,
            'postTags'   => $postTags,
            'categories' => $this->categoryModel()->all(),
            'error'      => null,
        ]);
    }

    public function update(Request $req, array $params): Response
    {
        $this->auth()->requireRole('superadmin', 'site-admin', 'editor', 'author');
        if (!$this->auth()->verifyCsrf()) return $this->redirect('/admin/blog');
        $id   = (int) $params['id'];
        $data = [
            'title'      => trim($req->post('title', '')),
            'slug'       => trim($req->post('slug', '')),
            'body'       => $req->post('body', ''),
            'status'     => $req->post('status', 'draft'),
            'categories' => $req->post('categories', []),
            'tags'       => trim($req->post('tags', '')),
        ];
        if ($data['title'] === '') {
            return $this->layout('blog/form.php', [
                'user'       => $this->auth()->user(),
                'page'       => 'blog',
                'csrf'       => $this->auth()->csrfToken(),
                'title'      => 'Edit Post',
                'action'     => '/admin/blog/' . $id,
                'record'     => array_merge($this->postModel()->findById($id) ?? [], $data),
                'postCats'   => $data['categories'],
                'postTags'   => $data['tags'],
                'categories' => $this->categoryModel()->all(),
                'error'      => 'Title is required.',
            ]);
        }
        $this->postModel()->update($id, $data, (int) $this->auth()->id());
        return $this->redirect('/admin/blog');
    }

    public function delete(Request $req, array $params): Response
    {
        $this->auth()->requireRole('superadmin', 'site-admin', 'editor', 'author');
        if (!$this->auth()->verifyCsrf()) return $this->redirect('/admin/blog');
        $this->postModel()->softDelete((int) $params['id']);
        return $this->redirect('/admin/blog');
    }
}
"""

