namespace VeloCMS\Modules\Blog\Controllers;

use VeloCMS\Core\Application;
use VeloCMS\Core\Database;
use VeloCMS\Core\Request;
use VeloCMS\Core\Response;
use VeloCMS\Core\View;
use VeloCMS\Modules\Blog\Models\Post;
use VeloCMS\Modules\Blog\Models\Category;

class BlogController
{
    public function __construct(private readonly Application $app) {}

    public function index(Request $request, array $params): Response
    {
        $db    = $this->app->make(Database::class);
        $posts = (new Post($db->core()))->published();
        return (new Response())->html($this->themeView('blog-index.php', [
            'title' => 'Blog',
            'posts' => $posts,
        ]));
    }

    public function show(Request $request, array $params): Response
    {
        $db   = $this->app->make(Database::class);
        $post = (new Post($db->core()))->findBySlug($params['slug'] ?? '');
        if (!$post) {
            return (new Response())->html($this->themeView('404.php', ['title' => 'Not Found']), 404);
        }
        return (new Response())->html($this->themeView('blog-post.php', [
            'title' => $post['title'],
            'post'  => $post,
        ]));
    }

    public function category(Request $request, array $params): Response
    {
        $db   = $this->app->make(Database::class);
        $slug = $params['slug'] ?? '';
        $cat  = $this->app->make(Database::class)->core()->prepare(
            'SELECT * FROM categories WHERE slug = ? LIMIT 1'
        );
        $cat->execute([$slug]);
        $category = $cat->fetch();
        if (!$category) {
            return (new Response())->html($this->themeView('404.php', ['title' => 'Not Found']), 404);
        }
        $stmt = $db->core()->prepare(
            "SELECT p.*, u.name AS author_name FROM posts p
             JOIN post_categories pc ON pc.post_id = p.id
             LEFT JOIN users u ON u.id = p.author_id
             WHERE pc.category_id = ? AND p.status = 'published' AND p.deleted_at IS NULL
             ORDER BY p.published_at DESC"
        );
        $stmt->execute([$category['id']]);
        return (new Response())->html($this->themeView('blog-index.php', [
            'title'    => 'Category: ' . $category['name'],
            'posts'    => $stmt->fetchAll(),
            'category' => $category,
        ]));
    }

    private function themeView(string $template, array $data = []): string
    {
        $view = new View($this->app->basePath('themes/default/layouts'));
        return $view->with($data)->render($template);
    }
}
"""

