    {
        $this->auth()->requireRole('superadmin', 'site-admin');
        if (!$this->auth()->verifyCsrf()) return $this->redirect('/admin/navigation');
        $name = trim($req->post('name', ''));
        if ($name !== '') $this->model()->create($name);
        return $this->redirect('/admin/navigation');
    }

    public function edit(Request $req, array $params): Response
    {
        $this->auth()->requireRole('superadmin', 'site-admin');
        $menu = $this->model()->findById((int) $params['id']);
        if (!$menu) return $this->redirect('/admin/navigation');
        return $this->layout('navigation/edit.php', [
            'user'  => $this->auth()->user(),
            'page'  => 'navigation',
            'csrf'  => $this->auth()->csrfToken(),
            'menu'  => $menu,
            'items' => $this->model()->itemsFor($menu['id']),
        ]);
    }

    public function addItem(Request $req, array $params): Response
    {
        $this->auth()->requireRole('superadmin', 'site-admin');
        if (!$this->auth()->verifyCsrf()) return $this->redirect('/admin/navigation');
        $menuId = (int) $params['id'];
        $label  = trim($req->post('label', ''));
        $url    = trim($req->post('url', ''));
        if ($label !== '') {
            $this->model()->addItem($menuId, $label, $url, null, 0);
        }
        return $this->redirect('/admin/navigation/' . $menuId . '/edit');
