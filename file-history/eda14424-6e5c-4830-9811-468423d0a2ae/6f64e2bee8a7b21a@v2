files['modules/navigation/models/Menu.php'] = r"""<?php declare(strict_types=1);
namespace VeloCMS\Modules\Navigation\Models;

class Menu
{
    public function __construct(private readonly \PDO $pdo) {}

    public function all(): array
    {
        return $this->pdo->query('SELECT * FROM menus ORDER BY name')->fetchAll();
    }

    public function findById(int $id): ?array
    {
        $stmt = $this->pdo->prepare('SELECT * FROM menus WHERE id = ? LIMIT 1');
        $stmt->execute([$id]);
        return $stmt->fetch() ?: null;
    }

    public function findBySlug(string $slug): ?array
    {
        $stmt = $this->pdo->prepare('SELECT * FROM menus WHERE slug = ? LIMIT 1');
        $stmt->execute([$slug]);
        return $stmt->fetch() ?: null;
    }

    public function itemsFor(int $menuId): array
    {
        $stmt = $this->pdo->prepare(
            'SELECT * FROM menu_items WHERE menu_id = ? AND parent_id IS NULL ORDER BY sort_order'
        );
        $stmt->execute([$menuId]);
        return $stmt->fetchAll();
    }

    public function create(string $name): int
    {
        $slug = $this->uniqueSlug($this->slugify($name));
        $this->pdo->prepare('INSERT INTO menus (name, slug) VALUES (?, ?)')->execute([$name, $slug]);
        return (int) $this->pdo->lastInsertId();
    }

    public function delete(int $id): void
    {
        $this->pdo->prepare('DELETE FROM menus WHERE id = ?')->execute([$id]);
    }

    public function addItem(int $menuId, string $label, string $url, ?int $pageId, int $sort): void
    {
        $this->pdo->prepare(
            'INSERT INTO menu_items (menu_id, label, url, page_id, sort_order) VALUES (?, ?, ?, ?, ?)'
        )->execute([$menuId, $label, $url, $pageId, $sort]);
    }

    public function deleteItem(int $itemId): void
    {
        $this->pdo->prepare('DELETE FROM menu_items WHERE id = ?')->execute([$itemId]);
    }

    private function slugify(string $text): string
    {
        $text = mb_strtolower($text);
        $text = preg_replace('/[^a-z0-9\s-]/', '', $text) ?? $text;
        return trim(preg_replace('/[\s-]+/', '-', $text) ?? $text, '-');
    }

    private function uniqueSlug(string $slug): string
    {
        $original = $slug; $i = 1;
        while (true) {
            $stmt = $this->pdo->prepare('SELECT id FROM menus WHERE slug = ? LIMIT 1');
            $stmt->execute([$slug]);
            if (!$stmt->fetch()) break;
            $slug = $original . '-' . $i++;
        }
        return $slug;
    }
}
"""

