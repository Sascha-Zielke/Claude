    public function deleteItem(Request $req, array $params): Response
    {
        $this->auth()->requireRole('superadmin', 'site-admin');
        if (!$this->auth()->verifyCsrf()) return $this->redirect('/admin/navigation');
        $this->model()->deleteItem((int) $params['item_id']);
        return $this->redirect('/admin/navigation/' . $params['id'] . '/edit');
