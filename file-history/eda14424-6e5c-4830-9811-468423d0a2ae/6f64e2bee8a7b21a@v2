files['modules/media/models/Media.php'] = r"""<?php declare(strict_types=1);
namespace VeloCMS\Modules\Media\Models;

class Media
{
    public function __construct(
        private readonly \PDO   $pdo,
        private readonly string $uploadDir,
    ) {}

    public function all(): array
    {
        return $this->pdo->query(
            'SELECT m.*, u.name AS uploader_name FROM media m
             LEFT JOIN users u ON u.id = m.uploaded_by
             ORDER BY m.created_at DESC'
        )->fetchAll();
    }

    public function findById(int $id): ?array
    {
        $stmt = $this->pdo->prepare('SELECT * FROM media WHERE id = ? LIMIT 1');
        $stmt->execute([$id]);
        return $stmt->fetch() ?: null;
    }

    public function store(array $file, string $alt, string $caption, int $userId): int
    {
        $ext      = strtolower(pathinfo($file['name'], PATHINFO_EXTENSION));
        $safeName = bin2hex(random_bytes(12)) . '.' . $ext;
        $diskPath = rtrim($this->uploadDir, '/') . '/' . $safeName;

        if (!is_dir($this->uploadDir)) {
            mkdir($this->uploadDir, 0755, true);
        }
        if (!move_uploaded_file($file['tmp_name'], $diskPath)) {
            throw new \RuntimeException('Failed to move uploaded file.');
        }

        $this->pdo->prepare(
            'INSERT INTO media (filename, disk_path, mime_type, size, alt, caption, uploaded_by)
             VALUES (?, ?, ?, ?, ?, ?, ?)'
        )->execute([
            $file['name'],
            $diskPath,
            $file['type'],
            $file['size'],
            $alt,
            $caption,
            $userId,
        ]);
        return (int) $this->pdo->lastInsertId();
    }

    public function delete(int $id): void
    {
        $row = $this->findById($id);
        if ($row && file_exists($row['disk_path'])) {
            unlink($row['disk_path']);
        }
        $this->pdo->prepare('DELETE FROM media WHERE id = ?')->execute([$id]);
    }

    public static function isAllowedMime(string $mime): bool
    {
        return in_array($mime, [
            'image/jpeg', 'image/png', 'image/gif', 'image/webp', 'image/svg+xml',
            'application/pdf',
            'video/mp4', 'video/webm',
            'application/zip',
            'text/plain',
        ], true);
    }

    public function publicUrl(array $row): string
    {
        $filename = basename($row['disk_path']);
        return '/storage/uploads/' . $filename;
    }
}
"""

files['modules/media/admin/controllers/MediaAdminController.php'] = r"""<?php declare(strict_types=1);
namespace VeloCMS\Modules\Media\Admin;

use VeloCMS\Admin\BaseController;
use VeloCMS\Core\Config;
use VeloCMS\Core\Database;
use VeloCMS\Core\Request;
use VeloCMS\Core\Response;
use VeloCMS\Modules\Media\Models\Media;

class MediaAdminController extends BaseController
{
    private function model(): Media
    {
        $domain    = $this->app->make(Config::class)->get('SITE_DOMAIN', 'default');
        $uploadDir = $this->app->basePath('storage/' . $domain . '/uploads');
        return new Media($this->app->make(Database::class)->core(), $uploadDir);
    }

    public function index(Request $req, array $params): Response
    {
        $this->auth()->requireRole('superadmin', 'site-admin', 'editor');
        return $this->layout('media/index.php', [
            'user'  => $this->auth()->user(),
            'page'  => 'media',
            'csrf'  => $this->auth()->csrfToken(),
            'files' => $this->model()->all(),
            'error' => null,
        ]);
    }

    public function upload(Request $req, array $params): Response
    {
        $this->auth()->requireRole('superadmin', 'site-admin', 'editor');
        if (!$this->auth()->verifyCsrf()) return $this->redirect('/admin/media');

        $file = $_FILES['file'] ?? null;
        if (!$file || $file['error'] !== UPLOAD_ERR_OK) {
            return $this->mediaIndexWithError('No file uploaded or upload error.');
        }
        if (!Media::isAllowedMime($file['type'])) {
            return $this->mediaIndexWithError('File type not allowed: ' . $file['type']);
        }
        if ($file['size'] > 20 * 1024 * 1024) {
            return $this->mediaIndexWithError('File exceeds 20 MB limit.');
        }

        $alt     = trim($req->post('alt', ''));
        $caption = trim($req->post('caption', ''));

        try {
            $this->model()->store($file, $alt, $caption, (int) $this->auth()->id());
        } catch (\RuntimeException $e) {
            return $this->mediaIndexWithError($e->getMessage());
        }
        return $this->redirect('/admin/media');
    }

    public function delete(Request $req, array $params): Response
    {
        $this->auth()->requireRole('superadmin', 'site-admin', 'editor');
        if (!$this->auth()->verifyCsrf()) return $this->redirect('/admin/media');
        $this->model()->delete((int) $params['id']);
        return $this->redirect('/admin/media');
    }

    private function mediaIndexWithError(string $error): Response
    {
        return $this->layout('media/index.php', [
            'user'  => $this->auth()->user(),
            'page'  => 'media',
            'csrf'  => $this->auth()->csrfToken(),
            'files' => $this->model()->all(),
            'error' => $error,
        ]);
    }
}
"""

