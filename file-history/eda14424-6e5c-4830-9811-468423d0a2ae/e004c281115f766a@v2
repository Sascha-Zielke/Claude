        "                <input type=\"hidden\" name=\"checkin_date\"   value=\"<?= e($checkin) ?>\">\n"
        "                <input type=\"hidden\" name=\"checkout_date\"  value=\"<?= e($checkout) ?>\">\n"
        "                <?php endif ?>\n"
        "                <?php if ($package): ?>"
    )

    # c) Add daily summary rows before the existing date row in summary sidebar
    old_summary_date = (
        "                <?php if ($date): ?>\n"
        "                <div class=\"booking-summary-row\">\n"
        "                    <span>Date</span>\n"
        "                    <span><?= e($date) ?></span>\n"
        "                </div>\n"
        "                <?php endif ?>"
    )
    new_summary_date = (
        "                <?php if ($pricingType === 'daily' && $checkin): ?>\n"
        "                <div class=\"booking-summary-row\">\n"
        "                    <span>Check-in</span>\n"
        "                    <span><?= e($checkin) ?></span>\n"
        "                </div>\n"
        "                <div class=\"booking-summary-row\">\n"
        "                    <span>Check-out</span>\n"
        "                    <span><?= e($checkout) ?></span>\n"
        "                </div>\n"
        "                <div class=\"booking-summary-row\">\n"
        "                    <span>Duration</span>\n"
        "                    <span><?= (int)$dailyNights ?> night<?= $dailyNights !== 1 ? 's' : '' ?></span>\n"
        "                </div>\n"
        "                <div class=\"booking-summary-row booking-summary-total\">\n"
        "                    <span>Total</span>\n"
        "                    <span>&euro;<?= number_format($dailyTotal, 2) ?></span>\n"
        "                </div>\n"
        "                <?php elseif ($date): ?>\n"
        "                <div class=\"booking-summary-row\">\n"
        "                    <span>Date</span>\n"
        "                    <span><?= e($date) ?></span>\n"
        "                </div>\n"
        "                <?php endif ?>"
    )

    for old, new, label in [
        (old_top_vars,      new_top_vars,      'top PHP vars'),
        (old_hidden,        new_hidden,         'daily hidden inputs'),
        (old_summary_date,  new_summary_date,   'daily summary rows'),
    ]:
        if old in form:
            form = form.replace(old, new)
            print(f'OK  form.php — {label}')
        else:
            print(f'ERR form.php — pattern not found for {label}')

    with open(form_path, 'w') as f: f.write(form)
else:
    print('SKIP form.php — already updated')

php_lint(form_path, 'themes/default/booking/form.php')

print('\nDone.')
