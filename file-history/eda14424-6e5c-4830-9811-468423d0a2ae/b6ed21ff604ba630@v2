files['modules/pages/models/Page.php'] = r"""<?php declare(strict_types=1);
namespace VeloCMS\Modules\Pages\Models;

class Page
{
    public function __construct(private readonly \PDO $pdo) {}

    public function all(): array
    {
        return $this->pdo->query(
            'SELECT p.*, u.name AS author_name,
                    par.title AS parent_title
             FROM pages p
             LEFT JOIN users u   ON u.id  = p.created_by
             LEFT JOIN pages par ON par.id = p.parent_id
             WHERE p.deleted_at IS NULL
             ORDER BY p.parent_id, p.title'
        )->fetchAll();
    }

    public function findById(int $id): ?array
    {
        $stmt = $this->pdo->prepare(
            'SELECT * FROM pages WHERE id = ? AND deleted_at IS NULL LIMIT 1'
        );
        $stmt->execute([$id]);
        return $stmt->fetch() ?: null;
    }

    public function findBySlug(string $slug): ?array
    {
        $stmt = $this->pdo->prepare(
            "SELECT * FROM pages WHERE slug = ? AND status = 'published' AND deleted_at IS NULL LIMIT 1"
        );
        $stmt->execute([$slug]);
        return $stmt->fetch() ?: null;
    }

    public function create(array $data, int $userId): int
    {
        $slug = $this->uniqueSlug($data['slug'] ?: $this->slugify($data['title']));
        $this->pdo->prepare(
            'INSERT INTO pages (parent_id, title, slug, body, status, template, meta_title, meta_desc, published_at, created_by)
             VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)'
        )->execute([
            $data['parent_id'] ?: null,
            $data['title'],
            $slug,
            $data['body'],
            $data['status'],
            $data['template'] ?: 'default',
            $data['meta_title'],
            $data['meta_desc'],
            $data['status'] === 'published' ? date('Y-m-d H:i:s') : null,
            $userId,
        ]);
        $id = (int) $this->pdo->lastInsertId();
        $this->saveRevision($id, $data['body'], $userId);
        return $id;
    }

    public function update(int $id, array $data, int $userId): void
    {
        $slug = $this->uniqueSlug($data['slug'] ?: $this->slugify($data['title']), $id);
        $this->pdo->prepare(
            'UPDATE pages SET parent_id=?, title=?, slug=?, body=?, status=?, template=?,
             meta_title=?, meta_desc=?, published_at=?
             WHERE id=?'
        )->execute([
            $data['parent_id'] ?: null,
            $data['title'],
            $slug,
            $data['body'],
            $data['status'],
            $data['template'] ?: 'default',
            $data['meta_title'],
            $data['meta_desc'],
            $data['status'] === 'published' ? date('Y-m-d H:i:s') : null,
            $id,
        ]);
        $this->saveRevision($id, $data['body'], $userId);
        $this->pruneRevisions($id);
    }

    public function softDelete(int $id): void
    {
        $this->pdo->prepare('UPDATE pages SET deleted_at = NOW() WHERE id = ?')->execute([$id]);
    }

    public function saveRevision(int $pageId, string $body, int $userId): void
    {
        $this->pdo->prepare(
            'INSERT INTO page_revisions (page_id, body, saved_by) VALUES (?, ?, ?)'
        )->execute([$pageId, $body, $userId]);
    }

    public function pruneRevisions(int $pageId, int $keep = 10): void
    {
        $ids = $this->pdo->prepare(
            'SELECT id FROM page_revisions WHERE page_id = ? ORDER BY id DESC LIMIT 999 OFFSET ?'
        );
        $ids->execute([$pageId, $keep]);
        foreach ($ids->fetchAll() as $row) {
            $this->pdo->prepare('DELETE FROM page_revisions WHERE id = ?')->execute([$row['id']]);
        }
    }

    private function slugify(string $text): string
    {
        $text = mb_strtolower($text);
        $text = preg_replace('/[^a-z0-9\s-]/', '', $text) ?? $text;
        $text = preg_replace('/[\s-]+/', '-', $text) ?? $text;
        return trim($text, '-');
    }

    private function uniqueSlug(string $slug, int $excludeId = 0): string
    {
        $original = $slug;
        $i = 1;
        while (true) {
            $stmt = $this->pdo->prepare(
                'SELECT id FROM pages WHERE slug = ? AND id != ? AND deleted_at IS NULL LIMIT 1'
            );
            $stmt->execute([$slug, $excludeId]);
            if (!$stmt->fetch()) break;
            $slug = $original . '-' . $i++;
        }
        return $slug;
    }
}
"""

