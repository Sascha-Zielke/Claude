namespace VeloCMS\Modules\Pages\Admin;

use VeloCMS\Admin\BaseController;
use VeloCMS\Core\Database;
use VeloCMS\Core\Request;
use VeloCMS\Core\Response;
use VeloCMS\Modules\Pages\Models\Page;

class PageAdminController extends BaseController
{
    private function pageModel(): Page
    {
        return new Page($this->app->make(Database::class)->core());
    }

    public function index(Request $req, array $params): Response
    {
        $this->auth()->requireRole('superadmin', 'site-admin', 'editor');
        return $this->layout('pages/index.php', [
            'user'  => $this->auth()->user(),
            'page'  => 'pages',
            'pages' => $this->pageModel()->all(),
        ]);
    }

    public function create(Request $req, array $params): Response
    {
        $this->auth()->requireRole('superadmin', 'site-admin', 'editor');
        return $this->layout('pages/form.php', [
            'user'   => $this->auth()->user(),
            'page'   => 'pages',
            'csrf'   => $this->auth()->csrfToken(),
            'title'  => 'New Page',
            'action' => '/admin/pages',
            'record' => null,
            'pages'  => $this->pageModel()->all(),
            'error'  => null,
        ]);
    }

    public function store(Request $req, array $params): Response
    {
        $this->auth()->requireRole('superadmin', 'site-admin', 'editor');
        if (!$this->auth()->verifyCsrf()) {
            return $this->redirect('/admin/pages');
        }
        $data = [
            'title'      => trim($req->post('title', '')),
            'slug'       => trim($req->post('slug', '')),
            'body'       => $req->post('body', ''),
            'status'     => $req->post('status', 'draft'),
            'template'   => $req->post('template', 'default'),
            'parent_id'  => (int) $req->post('parent_id', '0'),
            'meta_title' => trim($req->post('meta_title', '')),
            'meta_desc'  => trim($req->post('meta_desc', '')),
        ];
        if ($data['title'] === '') {
            return $this->layout('pages/form.php', [
                'user'   => $this->auth()->user(),
                'page'   => 'pages',
                'csrf'   => $this->auth()->csrfToken(),
                'title'  => 'New Page',
                'action' => '/admin/pages',
                'record' => $data,
                'pages'  => $this->pageModel()->all(),
                'error'  => 'Title is required.',
            ]);
        }
        $this->pageModel()->create($data, (int) $this->auth()->id());
        return $this->redirect('/admin/pages');
    }

    public function edit(Request $req, array $params): Response
    {
        $this->auth()->requireRole('superadmin', 'site-admin', 'editor');
        $record = $this->pageModel()->findById((int) $params['id']);
        if (!$record) return $this->redirect('/admin/pages');
        return $this->layout('pages/form.php', [
            'user'   => $this->auth()->user(),
            'page'   => 'pages',
            'csrf'   => $this->auth()->csrfToken(),
            'title'  => 'Edit Page',
            'action' => '/admin/pages/' . $params['id'],
            'record' => $record,
            'pages'  => $this->pageModel()->all(),
            'error'  => null,
        ]);
    }

    public function update(Request $req, array $params): Response
    {
        $this->auth()->requireRole('superadmin', 'site-admin', 'editor');
        if (!$this->auth()->verifyCsrf()) return $this->redirect('/admin/pages');
        $id   = (int) $params['id'];
        $data = [
            'title'      => trim($req->post('title', '')),
            'slug'       => trim($req->post('slug', '')),
            'body'       => $req->post('body', ''),
            'status'     => $req->post('status', 'draft'),
            'template'   => $req->post('template', 'default'),
            'parent_id'  => (int) $req->post('parent_id', '0'),
            'meta_title' => trim($req->post('meta_title', '')),
            'meta_desc'  => trim($req->post('meta_desc', '')),
        ];
        if ($data['title'] === '') {
            $record = $this->pageModel()->findById($id) ?? $data;
            return $this->layout('pages/form.php', [
                'user'   => $this->auth()->user(),
                'page'   => 'pages',
                'csrf'   => $this->auth()->csrfToken(),
                'title'  => 'Edit Page',
                'action' => '/admin/pages/' . $id,
                'record' => array_merge($record, $data),
                'pages'  => $this->pageModel()->all(),
                'error'  => 'Title is required.',
            ]);
        }
        $this->pageModel()->update($id, $data, (int) $this->auth()->id());
        return $this->redirect('/admin/pages');
    }

    public function delete(Request $req, array $params): Response
    {
        $this->auth()->requireRole('superadmin', 'site-admin', 'editor');
        if (!$this->auth()->verifyCsrf()) return $this->redirect('/admin/pages');
        $this->pageModel()->softDelete((int) $params['id']);
        return $this->redirect('/admin/pages');
    }
}
"""

