files['modules/pages/controllers/PageController.php'] = r"""<?php declare(strict_types=1);
namespace VeloCMS\Modules\Pages\Controllers;

use VeloCMS\Core\Application;
use VeloCMS\Core\Database;
use VeloCMS\Core\Request;
use VeloCMS\Core\Response;
use VeloCMS\Core\View;
use VeloCMS\Modules\Pages\Models\Page;

class PageController
{
    public function __construct(private readonly Application $app) {}

    public function home(Request $request, array $params): Response
    {
        $db   = $this->app->make(Database::class);
        $page = (new Page($db->core()))->findBySlug('home');
        if ($page) {
            return $this->renderPage($page);
        }
        return (new Response())->html($this->themeView('welcome.php', ['title' => 'Welcome to VeloCMS']));
    }

    public function show(Request $request, array $params): Response
    {
        $slug = $params['slug'] ?? '';
        $db   = $this->app->make(Database::class);
        $page = (new Page($db->core()))->findBySlug($slug);
        if (!$page) {
            return (new Response())->html($this->themeView('404.php', ['title' => 'Page Not Found']), 404);
        }
        return $this->renderPage($page);
    }

    private function renderPage(array $page): Response
    {
        $html = $this->themeView('page.php', [
            'title'     => $page['title'],
            'page'      => $page,
            'metaTitle' => $page['meta_title'] ?: $page['title'],
            'metaDesc'  => $page['meta_desc'],
        ]);
        return (new Response())->html($html);
    }

    private function themeView(string $template, array $data = []): string
    {
        $view = new View($this->app->basePath('themes/default/layouts'));
        return $view->with($data)->render($template);
    }
}
"""

