namespace VeloCMS\Modules\Api\Admin;

use VeloCMS\Admin\BaseController;
use VeloCMS\Core\Database;
use VeloCMS\Core\Request;
use VeloCMS\Core\Response;
use VeloCMS\Modules\Api\Models\ApiKey;

class ApiKeyAdminController extends BaseController
{
    private function model(): ApiKey
    {
        return new ApiKey($this->app->make(Database::class)->core());
    }

    public function index(Request $req, array $params): Response
    {
        $this->auth()->requireRole('superadmin', 'site-admin');
        return $this->layout('api/index.php', [
            'user'    => $this->auth()->user(),
            'page'    => 'api',
            'csrf'    => $this->auth()->csrfToken(),
            'keys'    => $this->model()->all(),
            'newKey'  => null,
        ]);
    }

    public function create(Request $req, array $params): Response
    {
        $this->auth()->requireRole('superadmin', 'site-admin');
        if (!$this->auth()->verifyCsrf()) return $this->redirect('/admin/api');
        $name = trim($req->post('name', ''));
        if ($name === '') return $this->redirect('/admin/api');
        $token = $this->model()->create((int) $this->auth()->id(), $name);
        return $this->layout('api/index.php', [
            'user'   => $this->auth()->user(),
            'page'   => 'api',
            'csrf'   => $this->auth()->csrfToken(),
            'keys'   => $this->model()->all(),
            'newKey' => $token,
        ]);
    }

    public function revoke(Request $req, array $params): Response
    {
        $this->auth()->requireRole('superadmin', 'site-admin');
        if (!$this->auth()->verifyCsrf()) return $this->redirect('/admin/api');
        $this->model()->revoke((int) $params['id']);
        return $this->redirect('/admin/api');
    }
}
"""

