# ── modules/api/models/ApiKey.php ─────────────────────────────────────────────
files['modules/api/models/ApiKey.php'] = r"""<?php declare(strict_types=1);
namespace VeloCMS\Modules\Api\Models;

class ApiKey
{
    public function __construct(private readonly \PDO $pdo) {}

    public function all(): array
    {
        return $this->pdo->query(
            'SELECT k.*, u.name AS user_name FROM api_keys k
             LEFT JOIN users u ON u.id = k.user_id
             WHERE k.deleted_at IS NULL
             ORDER BY k.created_at DESC'
        )->fetchAll();
    }

    public function findByHash(string $hash): ?array
    {
        $stmt = $this->pdo->prepare(
            'SELECT * FROM api_keys WHERE key_hash = ? AND deleted_at IS NULL LIMIT 1'
        );
        $stmt->execute([$hash]);
        return $stmt->fetch() ?: null;
    }

    /** Create a new API key, returns the plain-text token (shown once). */
    public function create(int $userId, string $name): string
    {
        $token = bin2hex(random_bytes(32));
        $hash  = hash('sha256', $token);
        $this->pdo->prepare(
            'INSERT INTO api_keys (user_id, name, key_hash) VALUES (?, ?, ?)'
        )->execute([$userId, $name, $hash]);
        return $token;
    }

    public function revoke(int $id): void
    {
        $this->pdo->prepare(
            'UPDATE api_keys SET deleted_at = NOW() WHERE id = ?'
        )->execute([$id]);
    }

    public function touchLastUsed(int $id): void
    {
        $this->pdo->prepare(
            'UPDATE api_keys SET last_used_at = NOW() WHERE id = ?'
        )->execute([$id]);
    }
}
"""

# ── modules/api/controllers/ApiBaseController.php ────────────────────────────
files['modules/api/controllers/ApiBaseController.php'] = r"""<?php declare(strict_types=1);
namespace VeloCMS\Modules\Api\Controllers;

use VeloCMS\Core\Application;
use VeloCMS\Core\Cache;
use VeloCMS\Core\Database;
use VeloCMS\Core\Request;
use VeloCMS\Core\Response;
use VeloCMS\Modules\Api\Models\ApiKey;

abstract class ApiBaseController
{
    private const RATE_LIMIT  = 60;  // requests
    private const RATE_WINDOW = 60;  // seconds

    public function __construct(protected readonly Application $app) {}

    /** Authenticate request and return the API key row. Sends 401/429 on failure. */
    protected function authenticate(Request $request): ?array
    {
        $auth  = $request->header('Authorization', '');
        $token = str_starts_with($auth, 'Bearer ') ? substr($auth, 7) : null;

        if ($token === null) {
            $this->sendError(401, 'Missing Authorization header.')->send();
            return null;
        }

        $hash  = hash('sha256', $token);
        $db    = $this->app->make(Database::class)->core();
        $model = new ApiKey($db);
        $key   = $model->findByHash($hash);

        if (!$key) {
            $this->sendError(401, 'Invalid API key.')->send();
            return null;
        }

        // Rate limiting
        $cache    = $this->app->make(Cache::class);
        $cacheKey = 'api_rate:' . $hash;
        $count    = (int) ($cache->get($cacheKey) ?? 0);

        if ($count >= self::RATE_LIMIT) {
            $this->sendError(429, 'Rate limit exceeded. Max ' . self::RATE_LIMIT . ' req/min.')->send();
            return null;
        }

        $cache->set($cacheKey, $count + 1, self::RATE_WINDOW);
        $model->touchLastUsed((int) $key['id']);

        return $key;
    }

    protected function sendError(int $status, string $message): Response
    {
        return (new Response())->json([
            'error'   => $this->httpStatusText($status),
            'message' => $message,
        ], $status);
    }

    protected function paginate(array $all, int $page, int $perPage): array
    {
        $total  = count($all);
        $offset = ($page - 1) * $perPage;
        return [
            'data' => array_slice($all, $offset, $perPage),
            'meta' => [
                'total'    => $total,
                'page'     => $page,
                'per_page' => $perPage,
                'pages'    => (int) ceil($total / $perPage),
            ],
        ];
    }

    private function httpStatusText(int $code): string
    {
        return match ($code) {
            400 => 'Bad Request',    401 => 'Unauthorized',
            403 => 'Forbidden',      404 => 'Not Found',
            429 => 'Too Many Requests', default => 'Error',
        };
    }
}
"""

# ── modules/api/controllers/PagesApiController.php ───────────────────────────
files['modules/api/controllers/PagesApiController.php'] = r"""<?php declare(strict_types=1);
namespace VeloCMS\Modules\Api\Controllers;

use VeloCMS\Core\Database;
use VeloCMS\Core\Request;
use VeloCMS\Core\Response;

class PagesApiController extends ApiBaseController
{
    public function index(Request $request, array $params): Response
    {
        if (!$this->authenticate($request)) return (new Response());
        $db    = $this->app->make(Database::class)->core();
        $pages = $db->query(
            "SELECT id, title, slug, status, meta_title, meta_desc, published_at, updated_at
             FROM pages WHERE status='published' AND deleted_at IS NULL ORDER BY title"
        )->fetchAll();
        $page = max(1, (int) $request->query('page', '1'));
        return (new Response())->json($this->paginate($pages, $page, 20));
    }

    public function show(Request $request, array $params): Response
    {
        if (!$this->authenticate($request)) return (new Response());
        $db   = $this->app->make(Database::class)->core();
        $stmt = $db->prepare(
            "SELECT id, title, slug, body, status, meta_title, meta_desc, published_at, updated_at
             FROM pages WHERE id = ? AND status='published' AND deleted_at IS NULL LIMIT 1"
        );
        $stmt->execute([(int) $params['id']]);
        $page = $stmt->fetch();
        if (!$page) return $this->sendError(404, 'Page not found.');
        return (new Response())->json(['data' => $page]);
    }
}
"""

