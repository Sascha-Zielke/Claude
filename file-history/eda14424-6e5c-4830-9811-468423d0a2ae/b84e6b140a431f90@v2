# Write files
for rel_path, content in files.items():
    full_path = base + '/' + rel_path
    os.makedirs(os.path.dirname(full_path), exist_ok=True)
    with open(full_path, 'w') as f:
        f.write(content.lstrip('\n'))
    print('OK  ' + rel_path)

# ── Add routes to admin/routes.php ────────────────────────────────────────────
routes_path = base + '/admin/routes.php'
routes = open(routes_path).read()

if 'ProfileController' not in routes:
    routes += """
use VeloCMS\\Admin\\ProfileController;

// ── Profile / password change ─────────────────────────────────────────────────
$router->get('/admin/profile',           [ProfileController::class, 'show']);
$router->post('/admin/profile/password', [ProfileController::class, 'changePassword']);
"""
    open(routes_path, 'w').write(routes)
    print('OK  admin/routes.php (profile routes added)')
else:
    print('OK  admin/routes.php (profile routes already present)')

# ── Add "My Profile" link to admin layout header/nav ─────────────────────────
layout_path = base + '/admin/views/layout.php'
layout = open(layout_path).read()

# Add profile link in the top-right user area if it exists, else add to sidebar
if 'href="/admin/profile"' not in layout:
    # Look for logout link and add profile before it
    if 'href="/admin/logout"' in layout:
        layout = layout.replace(
            'href="/admin/logout"',
            'href="/admin/profile">My Profile</a> &nbsp;|&nbsp; <a href="/admin/logout"'
        )
        # Remove duplicate text if it got duplicated
        open(layout_path, 'w').write(layout)
        print('OK  admin/views/layout.php (profile link added)')
    else:
        print('WARN admin/views/layout.php: could not find logout link — add profile link manually')
else:
    print('OK  admin/views/layout.php (profile link already present)')

print('\nProfile / password-change feature deployed.')
