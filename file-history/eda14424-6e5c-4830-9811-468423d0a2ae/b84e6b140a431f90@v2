import os

base = '/var/www/velocms'
files = {}

# ── admin/controllers/ProfileController.php ──────────────────────────────────
files['admin/controllers/ProfileController.php'] = r"""<?php declare(strict_types=1);
namespace VeloCMS\Admin;

use VeloCMS\Core\Auth;
use VeloCMS\Core\Request;
use VeloCMS\Core\Response;
use VeloCMS\Modules\Audit\Models\AuditLog;

class ProfileController extends BaseController
{
    public function show(Request $request, array $params): Response
    {
        $auth = $this->auth();
        if (!$auth->check()) {
            return $this->redirect('/admin/login');
        }
        return $this->layout('profile.php', [
            'page' => 'profile',
            'user' => $auth->user(),
        ]);
    }

    public function changePassword(Request $request, array $params): Response
    {
        $auth = $this->auth();
        if (!$auth->check()) {
            return $this->redirect('/admin/login');
        }

        Auth::verifyCsrf();

        $current  = trim($request->post('current_password', ''));
        $new      = trim($request->post('new_password', ''));
        $confirm  = trim($request->post('confirm_password', ''));

        $error = null;

        if ($current === '' || $new === '' || $confirm === '') {
            $error = 'All fields are required.';
        } elseif (strlen($new) < 12) {
            $error = 'New password must be at least 12 characters.';
        } elseif ($new !== $confirm) {
            $error = 'New passwords do not match.';
        } else {
            $db   = $this->app->make(\VeloCMS\Core\Database::class);
            $pdo  = $db->core();
            $user = $auth->user();

            $row = $pdo->prepare('SELECT password_hash FROM users WHERE id = ?');
            $row->execute([$user['id']]);
            $hash = $row->fetchColumn();

            if (!password_verify($current, $hash)) {
                $error = 'Current password is incorrect.';
            } else {
                $newHash = password_hash($new, PASSWORD_DEFAULT);
                $pdo->prepare('UPDATE users SET password_hash = ?, updated_at = NOW() WHERE id = ?')
                    ->execute([$newHash, $user['id']]);

                AuditLog::write(
                    $pdo,
                    $user['id'],
                    'PASSWORD_CHANGED',
                    'user',
                    $user['id'],
                    [],
                    $request->ip()
                );

                $_SESSION['_flash'] = 'Password changed successfully.';
                return $this->redirect('/admin/profile');
            }
        }

        return $this->layout('profile.php', [
            'page'  => 'profile',
            'user'  => $auth->user(),
            'error' => $error,
        ]);
    }
}
"""

# ── admin/views/profile.php ───────────────────────────────────────────────────
files['admin/views/profile.php'] = r"""<?php
