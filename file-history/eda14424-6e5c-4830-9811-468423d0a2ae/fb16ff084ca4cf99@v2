# ── public/index.php — add module loading + CSRF passthrough ─────────────────
index_path = base + '/public/index.php'
index = open(index_path).read()

module_loader = r"""
use VeloCMS\Core\Router;
use VeloCMS\Modules\Blog\BlogModule;
use VeloCMS\Modules\Pages\PagesModule;

// Load frontend modules (blog before pages so /blog/* routes take priority)
$router = $app->make(Router::class);
$modules = [
    new BlogModule($app),
    new PagesModule($app),
];
foreach ($modules as $module) {
    $module->register($router);
}
"""

if 'BlogModule' not in index:
    # Replace the old router line and health-check route with module loader
    old_index_block = """$router = $app->make(Router::class);

// ── Health-check / welcome route ──────────────────────────────────────────
// This will be replaced by module routes in Phase 2.
$router->get('/', static function (Request $request): Response {
    return (new Response())->json([
        'cms'     => 'VeloCMS',
        'version' => '0.1.0',
        'status'  => 'Phase 1 — Core framework operational',
        'php'     => PHP_VERSION,
        'host'    => $request->host(),
    ]);
});"""
    if old_index_block in index:
        index = index.replace(old_index_block, module_loader.strip())
    else:
        # Fallback: just append before admin/routes.php line
        index = index.replace(
            "require $app->basePath('admin/routes.php');",
            module_loader.strip() + "\n\nrequire $app->basePath('admin/routes.php');"
        )
    open(index_path, 'w').write(index)
    print('OK  public/index.php (module loading added)')
else:
    print('OK  public/index.php (already has module loading, skipped)')

