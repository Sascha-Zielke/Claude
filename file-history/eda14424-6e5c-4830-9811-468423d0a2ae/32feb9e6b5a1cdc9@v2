      <button type="button" class="vcms-btn vcms-btn--sm vcms-btn--ghost" onclick="moveDown(${i})" ${i===fields.length-1?'disabled':''}>↓</button>
      <button type="button" class="vcms-btn vcms-btn--sm vcms-btn--danger" onclick="remove(${i})">✕</button>
    </div>
  </div>
  ${(f.type==='select'||f.type==='radio') ? `
  <div style="margin-top:.5rem">
    <label style="font-size:.75rem;color:#64748b">Options (one per line)</label>
    <textarea rows="3" oninput="update(${i},'options',this.value.split('\\n').filter(Boolean))">${esc((f.options||[]).join('\\n'))}</textarea>
  </div>` : ''}
</div>`).join('');
    }
    document.getElementById('fields-json').value = JSON.stringify(fields);
}

function esc(s) {
    return String(s||'').replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}
function update(i, key, val) { fields[i][key] = val; sync(); }
function sync() { document.getElementById('fields-json').value = JSON.stringify(fields); }
function addField() {
    fields.push({label:'New Field',name:'field_'+Date.now(),type:'text',required:false});
    render();
}
function remove(i) { fields.splice(i,1); render(); }
function moveUp(i)   { if(i>0){ [fields[i-1],fields[i]]=[fields[i],fields[i-1]]; render(); } }
function moveDown(i) { if(i<fields.length-1){ [fields[i],fields[i+1]]=[fields[i+1],fields[i]]; render(); } }

// Auto-slug from name
document.getElementById('form-name').addEventListener('input', function() {
    const slugEl = document.getElementById('form-slug');
    if (!slugEl.dataset.edited) {
        slugEl.value = this.value.toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-|-$/g,'');
    }
});
document.getElementById('form-slug').addEventListener('input', function() {
    this.dataset.edited = '1';
});

render();
</script>

