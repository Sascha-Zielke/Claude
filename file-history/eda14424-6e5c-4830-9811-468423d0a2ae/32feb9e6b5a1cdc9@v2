namespace VeloCMS\Modules\Forms\Controllers;

use VeloCMS\Core\Application;
use VeloCMS\Core\Auth;
use VeloCMS\Core\Database;
use VeloCMS\Core\Mailer;
use VeloCMS\Core\Request;
use VeloCMS\Core\Response;
use VeloCMS\Core\View;
use VeloCMS\Modules\Audit\Models\AuditLog;
use VeloCMS\Modules\Email\Models\EmailQueue;
use VeloCMS\Modules\Forms\Models\Form;
use VeloCMS\Modules\Forms\Models\FormSubmission;
use VeloCMS\Modules\Settings\Models\Setting;

class FormController
{
    public function __construct(private readonly Application $app) {}

    public function show(Request $request, array $params): Response
    {
        $pdo  = $this->app->make(Database::class)->core();
        $form = (new Form($pdo))->findBySlug($params['slug'] ?? '');

        if (!$form) {
            return (new Response())->html('<h1>404 — Form not found</h1>')->status(404);
        }

        $auth = $this->app->make(Auth::class);
        $view = new View($this->app->basePath('themes/default/layouts'));
        $html = $view->with([
            'title'   => e($form['name']),
            'form'    => $form,
            'csrf'    => $auth->csrfToken(),
            'success' => $request->get('success') === '1',
            'errors'  => [],
        ])->render('form.php');

        return (new Response())->html($html);
    }

    public function submit(Request $request, array $params): Response
    {
        $pdo  = $this->app->make(Database::class)->core();
        $form = (new Form($pdo))->findBySlug($params['slug'] ?? '');

        if (!$form) {
            return (new Response())->status(404)->html('<h1>404</h1>');
        }

        // CSRF check
        $auth = $this->app->make(Auth::class);
        $auth->verifyCsrf();

        // Honeypot spam check
        if ($request->post('_hp', '') !== '') {
            return (new Response())->redirect('/forms/' . $form['slug'] . '?success=1');
        }

        // Validate required fields
        $errors = [];
        $data   = [];
        foreach ($form['fields'] as $field) {
            $name  = $field['name'];
            $value = trim($request->post($name, ''));
            if (($field['required'] ?? false) && $value === '') {
                $errors[$name] = ($field['label'] ?? $name) . ' is required.';
            }
            $data[$name] = $value;
        }

        if (!empty($errors)) {
            $view = new View($this->app->basePath('themes/default/layouts'));
            $html = $view->with([
                'title'   => e($form['name']),
                'form'    => $form,
                'csrf'    => $auth->csrfToken(),
                'success' => false,
                'errors'  => $errors,
                'posted'  => $data,
            ])->render('form.php');
            return (new Response())->html($html);
        }

        // Store submission
        $submissions = new FormSubmission($pdo);
        $id          = $submissions->create((int) $form['id'], $data, $request->ip());

        // Audit
        AuditLog::write($pdo, null, 'form.submission', 'form', (int) $form['id'],
            ['submission_id' => $id], $request->ip());

        // Email notification
        if (!empty($form['notify_email'])) {
            $fields = [];
            foreach ($form['fields'] as $field) {
                $fields[] = ['label' => $field['label'] ?? $field['name'], 'value' => $data[$field['name']] ?? ''];
            }
            $bodyHtml = $this->renderNotification($form['name'], $fields, $request->ip());
            $queue    = new EmailQueue($pdo);
            $queue->enqueue(
                $form['notify_email'],
                'New form submission: ' . $form['name'],
                $bodyHtml
            );
        }

        return (new Response())->redirect('/forms/' . $form['slug'] . '?success=1');
    }

    private function renderNotification(string $formName, array $fields, string $ip): string
    {
        $rows = '';
        foreach ($fields as $f) {
            $label = htmlspecialchars($f['label'], ENT_QUOTES, 'UTF-8');
            $value = nl2br(htmlspecialchars($f['value'], ENT_QUOTES, 'UTF-8'));
            $rows .= "<tr><th style='text-align:left;padding:.5rem;background:#f8fafc;width:140px'>{$label}</th>"
                   . "<td style='padding:.5rem'>{$value}</td></tr>";
        }
        $name    = htmlspecialchars($formName, ENT_QUOTES, 'UTF-8');
        $when    = htmlspecialchars(date('Y-m-d H:i:s'), ENT_QUOTES, 'UTF-8');
        $ipSafe  = htmlspecialchars($ip, ENT_QUOTES, 'UTF-8');
        $site    = htmlspecialchars(setting('site', 'name', 'VeloCMS'), ENT_QUOTES, 'UTF-8');

        return <<<HTML
<!DOCTYPE html><html><head><meta charset="utf-8"></head><body style="font-family:sans-serif;padding:2rem">
<h2 style="margin-top:0">New submission: {$name}</h2>
<table style="width:100%;border-collapse:collapse;border:1px solid #e2e8f0">{$rows}</table>
<p style="color:#94a3b8;font-size:.8rem;margin-top:1rem">Submitted {$when} from {$ipSafe}</p>
<p style="color:#94a3b8;font-size:.8rem">{$site}</p>
</body></html>
HTML;
    }
}
"""

