namespace VeloCMS\Modules\Forms\Models;

class Form
{
    public function __construct(private readonly \PDO $pdo) {}

    public function all(): array
    {
        return $this->pdo->query(
            'SELECT f.*, COUNT(s.id) AS submission_count
             FROM forms f
             LEFT JOIN form_submissions s ON s.form_id = f.id
             GROUP BY f.id
             ORDER BY f.name'
        )->fetchAll();
    }

    public function findById(int $id): ?array
    {
        $stmt = $this->pdo->prepare('SELECT * FROM forms WHERE id = ? LIMIT 1');
        $stmt->execute([$id]);
        $row = $stmt->fetch();
        if (!$row) return null;
        $row['fields'] = json_decode($row['fields_json'], true) ?: [];
        return $row;
    }

    public function findBySlug(string $slug): ?array
    {
        $stmt = $this->pdo->prepare('SELECT * FROM forms WHERE slug = ? LIMIT 1');
        $stmt->execute([$slug]);
        $row = $stmt->fetch();
        if (!$row) return null;
        $row['fields'] = json_decode($row['fields_json'], true) ?: [];
        return $row;
    }

    public function create(array $data): int
    {
        $this->pdo->prepare(
            'INSERT INTO forms (name, slug, fields_json, notify_email) VALUES (?, ?, ?, ?)'
        )->execute([
            $data['name'],
            $this->uniqueSlug($data['slug'] ?? $this->slugify($data['name'])),
            $data['fields_json'] ?? '[]',
            $data['notify_email'] ?? null,
        ]);
        return (int) $this->pdo->lastInsertId();
    }

    public function update(int $id, array $data): void
    {
        $this->pdo->prepare(
            'UPDATE forms SET name = ?, slug = ?, fields_json = ?, notify_email = ?,
             updated_at = NOW() WHERE id = ?'
        )->execute([
            $data['name'],
            $data['slug'],
            $data['fields_json'] ?? '[]',
            $data['notify_email'] ?: null,
            $id,
        ]);
    }

    public function delete(int $id): void
    {
        $this->pdo->prepare('DELETE FROM forms WHERE id = ?')->execute([$id]);
    }

    private function slugify(string $text): string
    {
        $text = strtolower(trim($text));
        $text = preg_replace('/[^a-z0-9]+/', '-', $text) ?? $text;
        return trim($text, '-');
    }

    private function uniqueSlug(string $base): string
    {
        $slug = $base;
        $i    = 1;
        while (true) {
            $stmt = $this->pdo->prepare('SELECT id FROM forms WHERE slug = ? LIMIT 1');
            $stmt->execute([$slug]);
            if (!$stmt->fetch()) return $slug;
            $slug = $base . '-' . $i++;
        }
    }
}
"""

