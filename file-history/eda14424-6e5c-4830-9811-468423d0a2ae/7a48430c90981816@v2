for rel_path, content in files.items():
    full_path = base + '/' + rel_path
    os.makedirs(os.path.dirname(full_path), exist_ok=True)
    with open(full_path, 'w') as f:
        f.write(content.lstrip('\n'))
    print('OK  ' + rel_path)

# ── Nginx: create symlink so /assets/theme/ serves themes/default/assets/ ────
theme_assets_src = base + '/themes/default/assets'
theme_assets_link = base + '/public/assets/theme'
if not os.path.exists(theme_assets_link):
    os.symlink(theme_assets_src, theme_assets_link)
    print('OK  public/assets/theme -> themes/default/assets (symlink)')
else:
    print('OK  public/assets/theme symlink already exists')

# ── Nginx: create symlink so /storage/uploads/ serves uploaded files ──────────
# The actual upload path depends on domain; for now link the storage root
storage_link = base + '/public/storage'
storage_src  = base + '/storage'
if not os.path.exists(storage_link):
    os.symlink(storage_src, storage_link)
    print('OK  public/storage -> storage (symlink)')
else:
    print('OK  public/storage symlink already exists')

