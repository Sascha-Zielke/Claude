# ── public/assets/admin/editor.js — rich text editor ─────────────────────────
files['public/assets/admin/editor.js'] = r"""(function () {
  'use strict';

  const editor   = document.getElementById('vcms-editor');
  const textarea = document.getElementById('vcms-body');
  const toolbar  = document.getElementById('editor-toolbar');

  if (!editor || !textarea || !toolbar) return;

  // Sync contenteditable → hidden textarea on every keystroke
  editor.addEventListener('input', () => { textarea.value = editor.innerHTML; });

  // Sync before form submit (catches paste/drag events too)
  editor.closest('form')?.addEventListener('submit', () => {
    textarea.value = editor.innerHTML;
  });

  // Toolbar button handler
  toolbar.addEventListener('click', e => {
    const btn = e.target.closest('[data-cmd]');
    if (!btn) return;
    e.preventDefault();
    editor.focus();
    const cmd = btn.dataset.cmd;
    switch (cmd) {
      case 'bold':          document.execCommand('bold');                      break;
      case 'italic':        document.execCommand('italic');                    break;
      case 'h2':            document.execCommand('formatBlock', false, 'h2'); break;
      case 'h3':            document.execCommand('formatBlock', false, 'h3'); break;
      case 'ul':            document.execCommand('insertUnorderedList');       break;
      case 'ol':            document.execCommand('insertOrderedList');         break;
      case 'blockquote':    document.execCommand('formatBlock', false, 'blockquote'); break;
      case 'removeFormat':  document.execCommand('removeFormat');              break;
      case 'link': {
        const url = prompt('Enter URL:');
        if (url) document.execCommand('createLink', false, url);
        break;
      }
    }
    textarea.value = editor.innerHTML;
  });

  // Keyboard shortcuts
  editor.addEventListener('keydown', e => {
    if (e.ctrlKey || e.metaKey) {
      if (e.key === 'b') { e.preventDefault(); document.execCommand('bold'); }
      if (e.key === 'i') { e.preventDefault(); document.execCommand('italic'); }
      if (e.key === 'k') {
        e.preventDefault();
        const url = prompt('Enter URL:');
        if (url) document.execCommand('createLink', false, url);
      }
    }
    textarea.value = editor.innerHTML;
  });

  // Initialise textarea with current editor content
  textarea.value = editor.innerHTML;
})();
"""

# ── public/assets/admin/slug.js — auto-slug from title ───────────────────────
files['public/assets/admin/slug.js'] = r"""(function () {
  'use strict';

  const titleInput = document.getElementById('f-title');
  const slugInput  = document.getElementById('f-slug');

  if (!titleInput || !slugInput) return;

  let userEdited = slugInput.value.trim() !== '';

  function slugify(text) {
    return text
      .toLowerCase()
      .replace(/[^a-z0-9\s-]/g, '')
      .trim()
      .replace(/[\s-]+/g, '-');
  }

  titleInput.addEventListener('input', () => {
    if (!userEdited) {
      slugInput.value = slugify(titleInput.value);
    }
  });

  slugInput.addEventListener('input', () => {
    userEdited = slugInput.value.trim() !== '';
  });

  slugInput.addEventListener('blur', () => {
    slugInput.value = slugify(slugInput.value);
  });
})();
"""

