"""vcms_s14a_model_detail.py
Fix 1 — Booking detail view daily display:
  - Booking::findById() adds r.daily_rate AS resource_daily_rate
  - Booking::update() new method
  - detail.php: daily-aware Date/Time/Duration rows + zero-rate warning
Fix 2 (partial) — detail.php: Edit + Cancel buttons
"""
BASE = '/var/www/velocms'
import subprocess

def php_lint(path, label=''):
    r = subprocess.run(['php', '-l', path], capture_output=True, text=True)
    print(('OK ' if r.returncode == 0 else 'ERR') + f'  php -l {label or path}')
    if r.returncode != 0: print(r.stderr)

# ── 1. Booking::findById() — add resource_daily_rate ─────────────────────────
model_path = BASE + '/modules/booking/models/Booking.php'
model = open(model_path).read()

old_find_by_id = (
    "            'SELECT b.*, r.name AS resource_name, r.slug AS resource_slug,\n"
    "                    pkg.name AS package_name, pkg.duration_mins AS package_duration,\n"
    "                    prd.name AS product_name\n"
)
new_find_by_id = (
    "            'SELECT b.*, r.name AS resource_name, r.slug AS resource_slug,\n"
    "                    r.daily_rate AS resource_daily_rate,\n"
    "                    pkg.name AS package_name, pkg.duration_mins AS package_duration,\n"
    "                    prd.name AS product_name\n"
)

if 'resource_daily_rate' not in model:
    if old_find_by_id in model:
        model = model.replace(old_find_by_id, new_find_by_id)
        print('OK  Booking::findById() — added resource_daily_rate')
    else:
        print('ERR Booking::findById() — pattern not found')
else:
    print('SKIP Booking::findById() — already updated')

# ── 2. Booking::update() — new method ────────────────────────────────────────
if 'public function update(' not in model:
    old_count_by_status = (
        "    public function countByStatus(): array\n"
        "    {"
    )
    new_update_then_count = (
        "    public function update(int $id, array $data): void\n"
        "    {\n"
        "        $this->pdo->prepare(\n"
        "            'UPDATE bookings\n"
        "             SET resource_id    = ?, booking_date  = ?, end_date      = ?, nights       = ?,\n"
        "                 start_time     = ?, end_time      = ?, duration_mins = ?,\n"
        "                 pricing_type   = ?, subtotal      = ?, total_amount  = ?,\n"
        "                 booking_status = ?, admin_notes   = ?, updated_at    = NOW()\n"
        "             WHERE id = ?'\n"
        "        )->execute([\n"
        "            (int) $data['resource_id'],\n"
        "            $data['booking_date'],\n"
        "            $data['end_date'] ?? null,\n"
        "            isset($data['nights']) ? (int) $data['nights'] : null,\n"
        "            $data['start_time'],\n"
        "            $data['end_time'],\n"
        "            (int) $data['duration_mins'],\n"
        "            $data['pricing_type'],\n"
        "            (float) $data['subtotal'],\n"
        "            (float) $data['total_amount'],\n"
        "            $data['booking_status'],\n"
        "            $data['admin_notes'] ?? '',\n"
        "            $id,\n"
        "        ]);\n"
        "    }\n"
        "\n"
        "    public function countByStatus(): array\n"
        "    {"
    )
    if old_count_by_status in model:
        model = model.replace(old_count_by_status, new_update_then_count)
        print('OK  Booking::update() added')
    else:
        print('ERR Booking — countByStatus anchor not found')
else:
    print('SKIP Booking::update() — already present')

with open(model_path, 'w') as f: f.write(model)
php_lint(model_path, 'Booking.php')

