# ── cli/commands/EmailFlushCommand.php ────────────────────────────────────────
files['cli/commands/EmailFlushCommand.php'] = r"""<?php declare(strict_types=1);
namespace VeloCMS\Cli;

use VeloCMS\Core\Application;
use VeloCMS\Core\Database;
use VeloCMS\Core\Mailer;
use VeloCMS\Modules\Email\Models\EmailQueue;
use VeloCMS\Modules\Settings\Models\Setting;

class EmailFlushCommand
{
    public function __construct(private readonly Application $app) {}

    public function run(array $args): void
    {
        $pdo     = $this->app->make(Database::class)->core();
        $queue   = new EmailQueue($pdo);
        $setting = new Setting($pdo);

        $config  = $setting->all('email');
        $mailer  = new Mailer($config);

        $pending = $queue->getPending(50);

        if (empty($pending)) {
            echo "Email queue empty.\n";
            return;
        }

        $sent   = 0;
        $failed = 0;

        foreach ($pending as $email) {
            $ok = $mailer->send(
                $email['to_email'],
                $email['subject'],
                $email['body_html']
            );
            if ($ok) {
                $queue->markSent((int) $email['id']);
                $sent++;
            } else {
                $queue->markFailed((int) $email['id'], $mailer->lastError());
                $failed++;
                echo "  FAIL {$email['to_email']}: {$mailer->lastError()}\n";
            }
        }

        echo "Email flush complete. Sent: {$sent}, Failed: {$failed}\n";
    }
}
"""

