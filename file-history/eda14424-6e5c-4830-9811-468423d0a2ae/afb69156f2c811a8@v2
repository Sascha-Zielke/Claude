files['modules/email/models/EmailQueue.php'] = r"""<?php declare(strict_types=1);
namespace VeloCMS\Modules\Email\Models;

class EmailQueue
{
    public function __construct(private readonly \PDO $pdo) {}

    public function enqueue(string $to, string $subject, string $bodyHtml): void
    {
        $this->pdo->prepare(
            'INSERT INTO email_queue (to_email, subject, body_html) VALUES (?, ?, ?)'
        )->execute([$to, $subject, $bodyHtml]);
    }

    /** Returns up to $limit unsent emails with fewer than 3 failed attempts. */
    public function getPending(int $limit = 20): array
    {
        $stmt = $this->pdo->prepare(
            'SELECT * FROM email_queue
             WHERE sent_at IS NULL AND failed_at IS NULL AND attempts < 3
             ORDER BY created_at ASC
             LIMIT ?'
        );
        $stmt->execute([$limit]);
        return $stmt->fetchAll();
    }

    public function markSent(int $id): void
    {
        $this->pdo->prepare(
            'UPDATE email_queue SET sent_at = NOW() WHERE id = ?'
        )->execute([$id]);
    }

    public function markFailed(int $id, string $error): void
    {
        $this->pdo->prepare(
            'UPDATE email_queue
             SET attempts = attempts + 1,
                 error_msg = ?,
                 failed_at = CASE WHEN attempts + 1 >= 3 THEN NOW() ELSE NULL END
             WHERE id = ?'
        )->execute([mb_substr($error, 0, 499), $id]);
    }

    public function stats(): array
    {
        return $this->pdo->query(
            'SELECT
                SUM(sent_at IS NOT NULL)               AS sent,
                SUM(sent_at IS NULL AND failed_at IS NULL AND attempts < 3) AS pending,
                SUM(failed_at IS NOT NULL)             AS failed
             FROM email_queue'
        )->fetch() ?: ['sent' => 0, 'pending' => 0, 'failed' => 0];
    }
}
"""

