        form = form.replace(old_hidden_fields_row, '')
        with open(form_path, 'w') as f: f.write(form)
        print('OK  resources/form.php — removed min/max/advance/sort fields')
    else:
        print('ERR resources/form.php — fields row pattern not found')
else:
    print('SKIP resources/form.php — fields already removed')

php_lint(form_path, 'admin/views/booking/resources/form.php')

print('\nDone.')
