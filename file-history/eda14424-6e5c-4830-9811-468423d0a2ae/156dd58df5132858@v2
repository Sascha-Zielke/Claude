files['modules/search/models/SearchIndex.php'] = r"""<?php declare(strict_types=1);
namespace VeloCMS\Modules\Search\Models;

class SearchIndex
{
    public function __construct(private readonly \PDO $pdo) {}

    /**
     * Full-text boolean search. Title matches weighted 3x over body.
     * @return array<int, array<string,mixed>>
     */
    public function search(string $query, int $limit = 20): array
    {
        if (trim($query) === '') return [];

        $q = $this->booleanQuery($query);

        $stmt = $this->pdo->prepare(
            'SELECT *,
                    (MATCH(title) AGAINST (? IN BOOLEAN MODE) * 3
                     + MATCH(body)  AGAINST (? IN BOOLEAN MODE)) AS score
             FROM search_index
             WHERE MATCH(title, body) AGAINST (? IN BOOLEAN MODE)
             ORDER BY score DESC
             LIMIT ?'
        );
        $stmt->execute([$q, $q, $q, $limit]);
        return $stmt->fetchAll();
    }

    /** Quick autocomplete: title-only match, returns 8 suggestions. */
    public function autocomplete(string $query): array
    {
        if (strlen(trim($query)) < 2) return [];
        $stmt = $this->pdo->prepare(
            'SELECT title, url FROM search_index
             WHERE title LIKE ?
             ORDER BY title
             LIMIT 8'
        );
        $stmt->execute(['%' . $query . '%']);
        return $stmt->fetchAll();
    }

    public function upsert(string $type, int $id, string $title, string $body, string $url): void
    {
        $this->pdo->prepare(
            'INSERT INTO search_index (entity_type, entity_id, title, body, url)
             VALUES (?, ?, ?, ?, ?)
             ON DUPLICATE KEY UPDATE title=VALUES(title), body=VALUES(body), url=VALUES(url),
             updated_at=NOW()'
        )->execute([$type, $id, $title, strip_tags($body), $url]);
    }

    public function remove(string $type, int $id): void
    {
        $this->pdo->prepare(
            'DELETE FROM search_index WHERE entity_type = ? AND entity_id = ?'
        )->execute([$type, $id]);
    }

    public function rebuildAll(\PDO $pdo): int
    {
        $pdo->exec('TRUNCATE TABLE search_index');
        $count = 0;

        $pages = $pdo->query(
            "SELECT id, title, body, slug FROM pages WHERE status='published' AND deleted_at IS NULL"
        )->fetchAll();
        foreach ($pages as $p) {
            $this->upsert('page', (int)$p['id'], $p['title'], $p['body'], '/' . $p['slug']);
            $count++;
        }

        $posts = $pdo->query(
            "SELECT id, title, body, slug FROM posts WHERE status='published' AND deleted_at IS NULL"
        )->fetchAll();
        foreach ($posts as $p) {
            $this->upsert('post', (int)$p['id'], $p['title'], $p['body'], '/blog/' . $p['slug']);
            $count++;
        }

        return $count;
    }

    private function booleanQuery(string $raw): string
    {
        $words = preg_split('/\s+/', trim($raw)) ?: [];
        $parts = [];
        foreach ($words as $word) {
            $clean = preg_replace('/[^\w\x80-\xff]/', '', $word);
            if ($clean !== '' && strlen($clean) >= 3) {
                $parts[] = '+' . $clean . '*';
            }
        }
        return $parts ? implode(' ', $parts) : '+' . trim($raw) . '*';
    }
}
"""

# ── modules/search/controllers/SearchController.php ──────────────────────────
files['modules/search/controllers/SearchController.php'] = r"""<?php declare(strict_types=1);
namespace VeloCMS\Modules\Search\Controllers;

use VeloCMS\Core\Application;
use VeloCMS\Core\Database;
use VeloCMS\Core\Request;
use VeloCMS\Core\Response;
use VeloCMS\Core\View;
use VeloCMS\Modules\Search\Models\SearchIndex;

class SearchController
{
    public function __construct(private readonly Application $app) {}

    public function index(Request $request, array $params): Response
    {
        $q       = trim($request->query('q', ''));
        $db      = $this->app->make(Database::class)->core();
        $index   = new SearchIndex($db);

        // JSON autocomplete endpoint
        if ($request->header('Accept', '') === 'application/json' || $request->query('format') === 'json') {
            $suggestions = $index->autocomplete($q);
            return (new Response())->json(['data' => $suggestions]);
        }

        $results = $q !== '' ? $index->search($q) : [];

        $view = new View($this->app->basePath('themes/default/layouts'));
        $html = $view->with([
            'title'   => $q !== '' ? 'Search: ' . $q : 'Search',
            'query'   => $q,
            'results' => $results,
        ])->render('search.php');

        return (new Response())->html($html);
    }
}
"""

