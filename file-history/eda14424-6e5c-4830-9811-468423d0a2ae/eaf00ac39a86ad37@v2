    if (!cal) return;
    const resource   = cal.dataset.resource;
    const slotMins   = parseInt(cal.dataset.slotMins, 10) || 60;
    const today      = new Date();
    let   viewYear   = today.getFullYear();
    let   viewMonth  = today.getMonth(); // 0-based

    function pad(n) { return String(n).padStart(2, '0'); }
    function fmtDate(y, m, d) { return `${y}-${pad(m+1)}-${pad(d)}`; }
    function monthName(m) {
        return ['January','February','March','April','May','June',
                'July','August','September','October','November','December'][m];
    }

    function renderCalendar(year, month) {
        const firstDay  = new Date(year, month, 1).getDay(); // 0=Sun
        const daysInMon = new Date(year, month + 1, 0).getDate();
        const startOfWeek = (firstDay === 0) ? 6 : firstDay - 1; // Mon=0

        let html = `<div class="cal-header">
            <button class="cal-nav" id="cal-prev">‹</button>
            <span class="cal-title">${monthName(month)} ${year}</span>
            <button class="cal-nav" id="cal-next">›</button>
        </div>
        <div class="cal-grid">
            <div class="cal-dow">Mo</div><div class="cal-dow">Tu</div>
            <div class="cal-dow">We</div><div class="cal-dow">Th</div>
            <div class="cal-dow">Fr</div><div class="cal-dow">Sa</div>
            <div class="cal-dow">Su</div>`;

        for (let i = 0; i < startOfWeek; i++) {
            html += '<div class="cal-cell cal-empty"></div>';
        }
        const todayStr = fmtDate(today.getFullYear(), today.getMonth(), today.getDate());
        for (let d = 1; d <= daysInMon; d++) {
            const dateStr = fmtDate(year, month, d);
            const isPast  = dateStr < todayStr;
            const cls     = isPast ? 'cal-cell cal-past' : 'cal-cell cal-avail';
            const btn     = isPast
                ? `<div class="${cls}">${d}</div>`
                : `<button class="${cls}" data-date="${dateStr}">${d}</button>`;
            html += btn;
        }
        html += '</div>';
        cal.innerHTML = html;

        document.getElementById('cal-prev').addEventListener('click', () => {
            viewMonth--;
            if (viewMonth < 0) { viewMonth = 11; viewYear--; }
            renderCalendar(viewYear, viewMonth);
        });
        document.getElementById('cal-next').addEventListener('click', () => {
            viewMonth++;
            if (viewMonth > 11) { viewMonth = 0; viewYear++; }
            renderCalendar(viewYear, viewMonth);
        });

        cal.querySelectorAll('.cal-avail').forEach(btn => {
            btn.addEventListener('click', () => loadSlots(btn.dataset.date));
        });
    }

    function loadSlots(date) {
        const slotsDiv   = document.getElementById('booking-slots');
        const slotsHead  = document.getElementById('booking-slots-heading');
        const slotsList  = document.getElementById('booking-slots-list');
        slotsHead.textContent = date;
        slotsList.innerHTML   = '<p>Loading…</p>';
        slotsDiv.style.display = '';
        slotsDiv.scrollIntoView({ behavior: 'smooth' });

        fetch(`/booking/${resource}/availability?date=${date}`)
            .then(r => r.json())
            .then(data => {
                if (!data.slots || data.slots.length === 0) {
                    slotsList.innerHTML = '<p class="booking-no-slots">No availability on this date.</p>';
                    return;
                }
                slotsList.innerHTML = data.slots.map(s =>
                    `<a href="/booking/${resource}/book?date=${date}&start=${s.start}&pricing_type=hourly"
                        class="booking-slot-btn">${s.start} – ${s.end}</a>`
                ).join('');
            })
            .catch(() => { slotsList.innerHTML = '<p>Error loading slots.</p>'; });
    }

    renderCalendar(viewYear, viewMonth);
}());
</script>
