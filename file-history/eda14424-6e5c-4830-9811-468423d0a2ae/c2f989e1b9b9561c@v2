files['modules/audit/models/AuditLog.php'] = r"""<?php declare(strict_types=1);
namespace VeloCMS\Modules\Audit\Models;

class AuditLog
{
    public function __construct(private readonly \PDO $pdo) {}

    public static function write(
        \PDO    $pdo,
        ?int    $userId,
        string  $action,
        ?string $entityType = null,
        ?int    $entityId   = null,
        array   $meta       = [],
        string  $ip         = ''
    ): void {
        $pdo->prepare(
            'INSERT INTO audit_log (user_id, action, entity_type, entity_id, meta_json, ip)
             VALUES (?, ?, ?, ?, ?, ?)'
        )->execute([
            $userId,
            $action,
            $entityType,
            $entityId,
            $meta ? json_encode($meta) : null,
            $ip ?: ($_SERVER['REMOTE_ADDR'] ?? ''),
        ]);
    }

    public function paginate(
        int   $page    = 1,
        int   $perPage = 50,
        array $filters = []
    ): array {
        $where = ['1=1'];
        $bind  = [];

        if (!empty($filters['action'])) {
            $where[] = 'action LIKE ?';
            $bind[]  = '%' . $filters['action'] . '%';
        }
        if (!empty($filters['user_id'])) {
            $where[] = 'user_id = ?';
            $bind[]  = (int) $filters['user_id'];
        }

        $whereStr = implode(' AND ', $where);

        $countStmt = $this->pdo->prepare("SELECT COUNT(*) FROM audit_log WHERE {$whereStr}");
        $countStmt->execute($bind);
        $total = (int) $countStmt->fetchColumn();

        $offset   = ($page - 1) * $perPage;
        $dataStmt = $this->pdo->prepare(
            "SELECT a.*, u.name AS user_name
             FROM audit_log a
             LEFT JOIN users u ON u.id = a.user_id
             WHERE {$whereStr}
             ORDER BY a.created_at DESC
             LIMIT ? OFFSET ?"
        );
        $dataStmt->execute(array_merge($bind, [$perPage, $offset]));

        return [
            'items' => $dataStmt->fetchAll(),
            'total' => $total,
            'pages' => (int) ceil($total / $perPage),
            'page'  => $page,
        ];
    }

    public static function prune(\PDO $pdo, int $days = 90): int
    {
        $stmt = $pdo->prepare(
            'DELETE FROM audit_log WHERE created_at < DATE_SUB(NOW(), INTERVAL ? DAY)'
        );
        $stmt->execute([$days]);
        return $stmt->rowCount();
    }
}
"""

