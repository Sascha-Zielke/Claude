BASE = '/var/www/velocms'

# ── 1. Update SettingsAdminController::index() to load booking data ──────────
ctrl_path = BASE + '/modules/settings/admin/controllers/SettingsAdminController.php'
ctrl = open(ctrl_path).read()

old_use = 'use VeloCMS\Modules\Settings\Models\Setting;'
new_use = (
    'use VeloCMS\Modules\Settings\Models\Setting;\n'
    'use VeloCMS\Modules\Booking\Models\BookingResource;\n'
    'use VeloCMS\Modules\Booking\Models\BookingPackage;\n'
    'use VeloCMS\Modules\Booking\Models\BookingProduct;'
)

if 'BookingResource' not in ctrl:
    ctrl = ctrl.replace(old_use, new_use)
    print('OK  controller — use statements added')
else:
    print('SKIP controller — use statements already present')

old_index_return = (
    "        return $this->layout('settings/index.php', [\n"
    "            'user'        => $auth->user(),\n"
    "            'page'        => 'settings',\n"
    "            'definitions' => self::DEFINITIONS,\n"
    "            'current'     => $current,\n"
    "            'csrf'        => $auth->csrfToken(),\n"
    "            'flash'       => $_SESSION['_flash'] ?? null,\n"
    "        ]);"
)
new_index_return = (
    "        // Load booking resources + packages + products for inline management\n"
    "        $bkResources = [];\n"
    "        $bkPackages  = [];\n"
    "        $bkProducts  = [];\n"
    "        try {\n"
    "            $bkResources = (new BookingResource($pdo))->all();\n"
    "            $pkg = new BookingPackage($pdo);\n"
    "            $prd = new BookingProduct($pdo);\n"
    "            foreach ($bkResources as $res) {\n"
    "                $rid = $res['id'];\n"
    "                foreach ($pkg->allForResource($rid) as $p) $bkPackages[] = $p + ['resource_name' => $res['name']];\n"
    "                foreach ($prd->allForResource($rid) as $p) $bkProducts[] = $p + ['resource_name' => $res['name']];\n"
    "            }\n"
    "        } catch (\\Throwable $e) { /* booking tables may not exist yet */ }\n"
    "\n"
    "        return $this->layout('settings/index.php', [\n"
    "            'user'        => $auth->user(),\n"
    "            'page'        => 'settings',\n"
    "            'definitions' => self::DEFINITIONS,\n"
    "            'current'     => $current,\n"
    "            'csrf'        => $auth->csrfToken(),\n"
    "            'flash'       => $_SESSION['_flash'] ?? null,\n"
    "            'bkResources' => $bkResources,\n"
    "            'bkPackages'  => $bkPackages,\n"
    "            'bkProducts'  => $bkProducts,\n"
    "        ]);"
)

if 'bkResources' not in ctrl:
    ctrl = ctrl.replace(old_index_return, new_index_return)
    print('OK  controller — index() updated with booking data')
else:
    print('SKIP controller — index() already updated')

with open(ctrl_path, 'w') as f:
    f.write(ctrl)

