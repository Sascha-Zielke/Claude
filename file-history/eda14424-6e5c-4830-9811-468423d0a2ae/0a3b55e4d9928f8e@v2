# ── 3. PHP syntax checks ─────────────────────────────────────────────────────
import subprocess
for path, label in [(ctrl_path, 'SettingsAdminController.php'), (view_path, 'settings/index.php')]:
    if not path.endswith('.php'):
        continue
    r = subprocess.run(['php', '-l', path], capture_output=True, text=True)
    print(('OK ' if r.returncode == 0 else 'ERR') + f'  php -l {label}')
    if r.returncode != 0:
        print(r.stderr)

print('\nDone.')
