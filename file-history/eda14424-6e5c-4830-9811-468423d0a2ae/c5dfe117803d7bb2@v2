write('modules/booking/models/Booking.php', '''<?php declare(strict_types=1);
namespace VeloCMS\\Modules\\Booking\\Models;

class Booking
{
    public function __construct(private readonly \\PDO $pdo) {}

    public function all(array $filters = []): array
    {
        $where  = [\'b.deleted_at IS NULL\'];
        $params = [];

        if (!empty($filters[\'status\'])) {
            $where[]  = \'b.booking_status = ?\';
            $params[] = $filters[\'status\'];
        }
        if (!empty($filters[\'resource_id\'])) {
            $where[]  = \'b.resource_id = ?\';
            $params[] = (int) $filters[\'resource_id\'];
        }
        if (!empty($filters[\'date_from\'])) {
            $where[]  = \'b.booking_date >= ?\';
            $params[] = $filters[\'date_from\'];
        }
        if (!empty($filters[\'date_to\'])) {
            $where[]  = \'b.booking_date <= ?\';
            $params[] = $filters[\'date_to\'];
        }

        $sql = \'SELECT b.*, r.name AS resource_name
                FROM bookings b
                LEFT JOIN booking_resources r ON r.id = b.resource_id
                WHERE \' . implode(\' AND \', $where) .
               \' ORDER BY b.booking_date DESC, b.start_time DESC\';

        $stmt = $this->pdo->prepare($sql);
        $stmt->execute($params);
        return $stmt->fetchAll();
    }

    public function findById(int $id): ?array
    {
        $stmt = $this->pdo->prepare(
            \'SELECT b.*, r.name AS resource_name, r.slug AS resource_slug,
                    pkg.name AS package_name, pkg.duration_mins AS package_duration,
                    prd.name AS product_name
             FROM bookings b
             LEFT JOIN booking_resources r   ON r.id   = b.resource_id
             LEFT JOIN booking_packages  pkg ON pkg.id = b.package_id
             LEFT JOIN booking_products  prd ON prd.id = b.product_id
             WHERE b.id = ? AND b.deleted_at IS NULL LIMIT 1\'
        );
        $stmt->execute([$id]);
        return $stmt->fetch() ?: null;
    }

    public function findByReference(string $reference): ?array
    {
        $stmt = $this->pdo->prepare(
            \'SELECT b.*, r.name AS resource_name, r.slug AS resource_slug
             FROM bookings b
             LEFT JOIN booking_resources r ON r.id = b.resource_id
             WHERE b.reference = ? AND b.deleted_at IS NULL LIMIT 1\'
        );
        $stmt->execute([$reference]);
        return $stmt->fetch() ?: null;
    }

    public function create(array $data): int
    {
        $ref = $this->generateReference();
        $this->pdo->prepare(
            \'INSERT INTO bookings
              (reference, resource_id, package_id, product_id,
               customer_name, customer_email, customer_phone,
               booking_date, start_time, end_time, duration_mins,
               pricing_type, subtotal, deposit_amount, total_amount,
               payment_status, booking_status, notes, ip_address)
             VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)\'
        )->execute([
            $ref,
            (int) $data[\'resource_id\'],
            isset($data[\'package_id\']) && $data[\'package_id\'] ? (int) $data[\'package_id\'] : null,
            isset($data[\'product_id\']) && $data[\'product_id\'] ? (int) $data[\'product_id\'] : null,
            $data[\'customer_name\'],
            $data[\'customer_email\'],
            $data[\'customer_phone\'] ?? null,
            $data[\'booking_date\'],
            $data[\'start_time\'],
            $data[\'end_time\'],
            (int) $data[\'duration_mins\'],
            $data[\'pricing_type\'],
            (float) $data[\'subtotal\'],
            (float) ($data[\'deposit_amount\'] ?? 0),
            (float) $data[\'total_amount\'],
            $data[\'payment_status\'] ?? \'none\',
            $data[\'booking_status\'] ?? \'pending\',
            $data[\'notes\'] ?? null,
            $data[\'ip_address\'] ?? null,
        ]);
        return (int) $this->pdo->lastInsertId();
    }

    public function updateStatus(int $id, string $status, string $adminNotes = \'\'): void
    {
        $this->pdo->prepare(
            \'UPDATE bookings SET booking_status = ?, admin_notes = ?, updated_at = NOW() WHERE id = ?\'
        )->execute([$status, $adminNotes, $id]);
    }

    public function countByStatus(): array
    {
        $rows = $this->pdo->query(
            "SELECT booking_status, COUNT(*) AS cnt FROM bookings WHERE deleted_at IS NULL GROUP BY booking_status"
        )->fetchAll();
        $result = [\'pending\' => 0, \'confirmed\' => 0, \'cancelled\' => 0];
        foreach ($rows as $r) {
            $result[$r[\'booking_status\']] = (int) $r[\'cnt\'];
        }
        return $result;
    }

    public function upcomingForCalendar(int $resourceId = 0, int $days = 90): array
    {
        $params = [date(\'Y-m-d\'), date(\'Y-m-d\', strtotime("+{$days} days"))];
        $extra  = \'\';
        if ($resourceId > 0) {
            $extra    = \' AND b.resource_id = ?\';
            $params[] = $resourceId;
        }
        $stmt = $this->pdo->prepare(
            "SELECT b.*, r.name AS resource_name
             FROM bookings b
             LEFT JOIN booking_resources r ON r.id = b.resource_id
             WHERE b.booking_date BETWEEN ? AND ?
               AND b.booking_status != \'cancelled\'
               AND b.deleted_at IS NULL{$extra}
             ORDER BY b.booking_date ASC, b.start_time ASC"
        );
        $stmt->execute($params);
        return $stmt->fetchAll();
    }

    public function getBookedSlots(int $resourceId, string $date): array
    {
        $stmt = $this->pdo->prepare(
            "SELECT start_time, end_time FROM bookings
             WHERE resource_id = ? AND booking_date = ?
               AND booking_status != \'cancelled\'
               AND deleted_at IS NULL"
        );
        $stmt->execute([$resourceId, $date]);
        return $stmt->fetchAll();
    }

    public function generateAvailableSlots(
        int    $resourceId,
        string $date,
        array  $settings,
        int    $slotMins     = 60,
        int    $advanceHours = 24
    ): array {
        $businessStart = $settings[\'business_hours_start\'] ?? \'09:00\';
        $businessEnd   = $settings[\'business_hours_end\']   ?? \'21:00\';
        $businessDays  = json_decode($settings[\'business_days\'] ?? \'[1,2,3,4,5,6]\', true)
                         ?: [1, 2, 3, 4, 5, 6];

        $dayOfWeek = (int) date(\'N\', strtotime($date)); // 1=Mon … 7=Sun
        if (!in_array($dayOfWeek, $businessDays, true)) {
            return [];
        }

        $booked   = $this->getBookedSlots($resourceId, $date);
        $start    = strtotime("{$date} {$businessStart}");
        $end      = strtotime("{$date} {$businessEnd}");
        $minStart = time() + ($advanceHours * 3600);

        $slots   = [];
        $current = $start;

        while ($current + ($slotMins * 60) <= $end) {
            $slotEnd = $current + ($slotMins * 60);

            if ($current < $minStart) {
                $current += $slotMins * 60;
                continue;
            }

            $conflict = false;
            foreach ($booked as $b) {
                $bookedStart = strtotime("{$date} {$b[\'start_time\']}");
                $bookedEnd   = strtotime("{$date} {$b[\'end_time\']}");
                if ($current < $bookedEnd && $slotEnd > $bookedStart) {
                    $conflict = true;
                    break;
                }
            }

            if (!$conflict) {
                $slots[] = [
                    \'start\' => date(\'H:i\', $current),
                    \'end\'   => date(\'H:i\', $slotEnd),
                ];
            }
            $current += $slotMins * 60;
        }
        return $slots;
    }

    public function generateReference(): string
    {
        do {
            $ref  = \'BK-\' . strtoupper(substr(md5(uniqid(\'\', true)), 0, 8));
            $stmt = $this->pdo->prepare(\'SELECT id FROM bookings WHERE reference = ? LIMIT 1\');
            $stmt->execute([$ref]);
        } while ($stmt->fetch());
        return $ref;
    }
}
''')

