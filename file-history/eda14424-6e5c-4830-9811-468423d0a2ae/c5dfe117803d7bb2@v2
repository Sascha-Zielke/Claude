write('modules/booking/admin/controllers/ResourceAdminController.php', '''<?php declare(strict_types=1);
namespace VeloCMS\\Modules\\Booking\\Admin;

use VeloCMS\\Admin\\BaseController;
use VeloCMS\\Core\\Database;
use VeloCMS\\Core\\Request;
use VeloCMS\\Core\\Response;
use VeloCMS\\Modules\\Booking\\Models\\BookingResource;
use VeloCMS\\Modules\\Booking\\Models\\BookingPackage;
use VeloCMS\\Modules\\Booking\\Models\\BookingProduct;

class ResourceAdminController extends BaseController
{
    private function pdo(): \\PDO
    {
        return $this->app->make(Database::class)->core();
    }
    private function resource(): BookingResource { return new BookingResource($this->pdo()); }
    private function package(): BookingPackage   { return new BookingPackage($this->pdo()); }
    private function product(): BookingProduct   { return new BookingProduct($this->pdo()); }

    public function index(Request $req, array $params): Response
    {
        $this->auth()->requireRole(\'superadmin\', \'site-admin\');
        $flash = $_SESSION[\'_flash\'] ?? null;
        unset($_SESSION[\'_flash\']);
        return $this->layout(\'booking/resources/index.php\', [
            \'user\'      => $this->auth()->user(),
            \'page\'      => \'booking\',
            \'resources\' => $this->resource()->all(),
            \'flash\'     => $flash,
        ]);
    }

    public function create(Request $req, array $params): Response
    {
        $this->auth()->requireRole(\'superadmin\', \'site-admin\');
        return $this->layout(\'booking/resources/form.php\', [
            \'user\'     => $this->auth()->user(),
            \'page\'     => \'booking\',
            \'csrf\'     => $this->auth()->csrfToken(),
            \'formTitle\'=> \'New Resource\',
            \'action\'   => \'/admin/booking/resources\',
            \'record\'   => null,
            \'packages\' => [],
            \'products\' => [],
            \'flash\'    => null,
            \'error\'    => null,
        ]);
    }

    public function store(Request $req, array $params): Response
    {
        $this->auth()->requireRole(\'superadmin\', \'site-admin\');
        if (!$this->auth()->verifyCsrf()) {
            return $this->redirect(\'/admin/booking/resources\');
        }
        $data = $this->extractData($req);
        if ($data[\'name\'] === \'\') {
            return $this->layout(\'booking/resources/form.php\', [
                \'user\'     => $this->auth()->user(), \'page\' => \'booking\',
                \'csrf\'     => $this->auth()->csrfToken(),
                \'formTitle\'=> \'New Resource\', \'action\' => \'/admin/booking/resources\',
                \'record\'   => $data, \'packages\' => [], \'products\' => [],
                \'flash\'    => null, \'error\' => \'Name is required.\',
            ]);
        }
        $this->resource()->create($data);
        $_SESSION[\'_flash\'] = \'Resource created.\';
        return $this->redirect(\'/admin/booking/resources\');
    }

    public function edit(Request $req, array $params): Response
    {
        $this->auth()->requireRole(\'superadmin\', \'site-admin\');
        $record = $this->resource()->findById((int) $params[\'id\']);
        if (!$record) {
            return $this->redirect(\'/admin/booking/resources\');
        }
        $flash = $_SESSION[\'_flash\'] ?? null;
        unset($_SESSION[\'_flash\']);
        return $this->layout(\'booking/resources/form.php\', [
            \'user\'     => $this->auth()->user(),
            \'page\'     => \'booking\',
            \'csrf\'     => $this->auth()->csrfToken(),
            \'formTitle\'=> \'Edit Resource\',
            \'action\'   => \'/admin/booking/resources/\' . $params[\'id\'],
            \'record\'   => $record,
            \'packages\' => $this->package()->allForResource((int) $params[\'id\']),
            \'products\' => $this->product()->allForResource((int) $params[\'id\']),
            \'flash\'    => $flash,
            \'error\'    => null,
        ]);
    }

    public function update(Request $req, array $params): Response
    {
        $this->auth()->requireRole(\'superadmin\', \'site-admin\');
        if (!$this->auth()->verifyCsrf()) {
            return $this->redirect(\'/admin/booking/resources\');
        }
        $id   = (int) $params[\'id\'];
        $data = $this->extractData($req);
        if ($data[\'name\'] === \'\') {
            return $this->layout(\'booking/resources/form.php\', [
                \'user\'     => $this->auth()->user(), \'page\' => \'booking\',
                \'csrf\'     => $this->auth()->csrfToken(),
                \'formTitle\'=> \'Edit Resource\',
                \'action\'   => \'/admin/booking/resources/\' . $id,
                \'record\'   => array_merge($this->resource()->findById($id) ?? [], $data),
                \'packages\' => $this->package()->allForResource($id),
                \'products\' => $this->product()->allForResource($id),
                \'flash\'    => null, \'error\' => \'Name is required.\',
            ]);
        }
        $this->resource()->update($id, $data);
        $_SESSION[\'_flash\'] = \'Resource updated.\';
        return $this->redirect(\'/admin/booking/resources/\' . $id . \'/edit\');
    }

    public function delete(Request $req, array $params): Response
    {
        $this->auth()->requireRole(\'superadmin\', \'site-admin\');
        if (!$this->auth()->verifyCsrf()) {
            return $this->redirect(\'/admin/booking/resources\');
        }
        $this->resource()->softDelete((int) $params[\'id\']);
        $_SESSION[\'_flash\'] = \'Resource deleted.\';
        return $this->redirect(\'/admin/booking/resources\');
    }

    // ── Package sub-routes ────────────────────────────────────────────────────

    public function storePackage(Request $req, array $params): Response
    {
        $this->auth()->requireRole(\'superadmin\', \'site-admin\');
        if (!$this->auth()->verifyCsrf()) {
            return $this->redirect(\'/admin/booking/resources\');
        }
        $resourceId = (int) $params[\'id\'];
        $name       = trim($req->post(\'pkg_name\', \'\'));
        if ($name !== \'\') {
            $this->package()->create([
                \'resource_id\'  => $resourceId,
                \'name\'         => $name,
                \'description\'  => trim($req->post(\'pkg_description\', \'\')),
                \'duration_mins\'=> (int) $req->post(\'pkg_duration_mins\', 60),
                \'price\'        => $req->post(\'pkg_price\', 0),
                \'active\'       => $req->post(\'pkg_active\', \'0\') === \'1\' ? 1 : 0,
