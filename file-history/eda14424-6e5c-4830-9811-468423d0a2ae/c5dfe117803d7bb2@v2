namespace VeloCMS\\Modules\\Booking\\Controllers;

use VeloCMS\\Core\\Application;
use VeloCMS\\Core\\Database;
use VeloCMS\\Core\\Request;
use VeloCMS\\Core\\Response;
use VeloCMS\\Core\\View;
use VeloCMS\\Modules\\Booking\\Models\\Booking;
use VeloCMS\\Modules\\Booking\\Models\\BookingResource;
use VeloCMS\\Modules\\Booking\\Models\\BookingPackage;
use VeloCMS\\Modules\\Booking\\Models\\BookingProduct;
use VeloCMS\\Modules\\Settings\\Models\\Setting;
use VeloCMS\\Modules\\Email\\Models\\EmailQueue;

class BookingController
{
    public function __construct(private readonly Application $app) {}

    private function pdo(): \\PDO
    {
        return $this->app->make(Database::class)->core();
    }

    private function settings(): array
    {
        return (new Setting($this->pdo()))->all(\'booking\');
    }

    private function render(string $tpl, array $data = []): Response
    {
        $view = new View($this->app->basePath(\'themes/default\'));
        $html = $view->with($data)->render($tpl);
        return (new Response())->html($html);
    }

    // ── Resource list ─────────────────────────────────────────────────────────

    public function index(Request $req, array $params): Response
    {
        $settings = $this->settings();
        if (empty($settings[\'enabled\'])) {
            return (new Response())->redirect(\'/\');
        }
        $resources = (new BookingResource($this->pdo()))->all(true);
        if (count($resources) === 1) {
            return (new Response())->redirect(\'/booking/\' . $resources[0][\'slug\']);
        }
        return $this->render(\'booking/index.php\', [
            \'resources\' => $resources,
            \'settings\'  => $settings,
        ]);
    }

    // ── Resource detail + date/time picker ────────────────────────────────────

    public function resource(Request $req, array $params): Response
    {
        $settings = $this->settings();
        if (empty($settings[\'enabled\'])) {
            return (new Response())->redirect(\'/\');
        }
        $resource = (new BookingResource($this->pdo()))->findBySlug($params[\'slug\']);
        if (!$resource || !(int) $resource[\'active\']) {
            return (new Response())->redirect(\'/booking\');
        }
        $packages = (new BookingPackage($this->pdo()))->allForResource((int) $resource[\'id\']);
        $products = (new BookingProduct($this->pdo()))->allForResource((int) $resource[\'id\']);

        return $this->render(\'booking/resource.php\', [
            \'resource\' => $resource,
            \'packages\' => $packages,
            \'products\' => $products,
            \'settings\' => $settings,
        ]);
    }

    // ── Availability JSON (AJAX) ───────────────────────────────────────────────

    public function availability(Request $req, array $params): Response
    {
        $resource = (new BookingResource($this->pdo()))->findBySlug($params[\'slug\']);
        if (!$resource) {
            return (new Response())->json([\'error\' => \'Resource not found\'], 404);
        }
        $date = $req->get(\'date\', \'\');
        if (!preg_match(\'/^\\d{4}-\\d{2}-\\d{2}$/\', $date)) {
            return (new Response())->json([\'error\' => \'Invalid date\'], 400);
        }
        $settings = $this->settings();
        $slots    = (new Booking($this->pdo()))->generateAvailableSlots(
            (int) $resource[\'id\'],
            $date,
            $settings,
            (int) ($settings[\'slot_duration_mins\'] ?? 60),
            (int) $resource[\'advance_booking_hours\']
        );
        return (new Response())->json([\'date\' => $date, \'slots\' => $slots]);
    }

    // ── Booking form ──────────────────────────────────────────────────────────

    public function bookForm(Request $req, array $params): Response
    {
        $settings = $this->settings();
        if (empty($settings[\'enabled\'])) {
            return (new Response())->redirect(\'/\');
        }
        $resource = (new BookingResource($this->pdo()))->findBySlug($params[\'slug\']);
        if (!$resource || !(int) $resource[\'active\']) {
            return (new Response())->redirect(\'/booking\');
        }

        $date      = $req->get(\'date\', \'\');
        $startTime = $req->get(\'start\', \'\');
        $packageId = (int) $req->get(\'package_id\', 0);
        $productId = (int) $req->get(\'product_id\', 0);

        $pkgModel  = new BookingPackage($this->pdo());
        $prodModel = new BookingProduct($this->pdo());

        return $this->render(\'booking/form.php\', [
            \'resource\'   => $resource,
            \'packages\'   => $pkgModel->allForResource((int) $resource[\'id\']),
            \'products\'   => $prodModel->allForResource((int) $resource[\'id\']),
            \'package\'    => $packageId ? $pkgModel->findById($packageId) : null,
            \'product\'    => $productId ? $prodModel->findById($productId) : null,
            \'date\'       => $date,
            \'start\'      => $startTime,
            \'settings\'   => $settings,
            \'error\'      => null,
        ]);
    }

    // ── Booking submission ────────────────────────────────────────────────────

    public function bookStore(Request $req, array $params): Response
    {
        $settings = $this->settings();
        if (empty($settings[\'enabled\'])) {
            return (new Response())->redirect(\'/\');
        }
        $resource = (new BookingResource($this->pdo()))->findBySlug($params[\'slug\']);
        if (!$resource || !(int) $resource[\'active\']) {
            return (new Response())->redirect(\'/booking\');
        }

        $name        = trim($req->post(\'customer_name\', \'\'));
        $email       = trim($req->post(\'customer_email\', \'\'));
        $phone       = trim($req->post(\'customer_phone\', \'\'));
        $date        = $req->post(\'booking_date\', \'\');
        $startTime   = $req->post(\'start_time\', \'\');
        $notes       = trim($req->post(\'notes\', \'\'));
        $pricingType = $req->post(\'pricing_type\', \'hourly\');
        $pkgId       = (int) $req->post(\'package_id\', 0);
        $prodId      = (int) $req->post(\'product_id\', 0);

        $errors = [];
        if ($name === \'\') {
            $errors[] = \'Name is required.\';
        }
        if (!filter_var($email, FILTER_VALIDATE_EMAIL)) {
            $errors[] = \'A valid email address is required.\';
        }
        if (!preg_match(\'/^\\d{4}-\\d{2}-\\d{2}$/\', $date)) {
            $errors[] = \'Please select a date.\';
        }
        if (!preg_match(\'/^\\d{2}:\\d{2}$/\', $startTime)) {
            $errors[] = \'Please select a start time.\';
        }

        $slotMins = (int) ($settings[\'slot_duration_mins\'] ?? 60);
        $endTs    = strtotime("{$date} {$startTime}") + $slotMins * 60;
        $endTime  = date(\'H:i\', $endTs);

        $pkgModel  = new BookingPackage($this->pdo());
        $prodModel = new BookingProduct($this->pdo());

        if ($pricingType === \'package\' && $pkgId) {
            $pkg = $pkgModel->findById($pkgId);
            if ($pkg) {
                $endTs    = strtotime("{$date} {$startTime}") + ((int) $pkg[\'duration_mins\'] * 60);
                $endTime  = date(\'H:i\', $endTs);
                $slotMins = (int) $pkg[\'duration_mins\'];
            }
        }

        if (!empty($errors)) {
            return $this->render(\'booking/form.php\', [
                \'resource\' => $resource,
                \'packages\' => $pkgModel->allForResource((int) $resource[\'id\']),
                \'products\' => $prodModel->allForResource((int) $resource[\'id\']),
                \'package\'  => $pkgId  ? $pkgModel->findById($pkgId)   : null,
                \'product\'  => $prodId ? $prodModel->findById($prodId) : null,
                \'date\'     => $date,
                \'start\'    => $startTime,
                \'settings\' => $settings,
                \'error\'    => implode(\' \', $errors),
            ]);
        }

        // Calculate price
        $subtotal      = 0.0;
        $actualPkgId   = null;
        $actualProdId  = null;

        if ($pricingType === \'hourly\') {
            $subtotal = round((float) $resource[\'hourly_rate\'] * ($slotMins / 60), 2);
        } elseif ($pricingType === \'package\' && $pkgId) {
            $pkg         = $pkgModel->findById($pkgId);
            $subtotal    = $pkg ? (float) $pkg[\'price\'] : 0.0;
            $actualPkgId = $pkgId;
        } elseif ($pricingType === \'product\' && $prodId) {
            $prod         = $prodModel->findById($prodId);
            $subtotal     = $prod ? (float) $prod[\'price\'] : 0.0;
            $actualProdId = $prodId;
        }

        $depPct  = (float) ($settings[\'deposit_percent\'] ?? 0);
        $deposit = ($settings[\'payment_mode\'] ?? \'none\') === \'deposit\'
            ? round($subtotal * $depPct / 100, 2) : 0.0;

        $needsConfirm = !empty($settings[\'require_confirmation\']);
        $status       = $needsConfirm ? \'pending\' : \'confirmed\';

        $bookingModel = new Booking($this->pdo());
        $id = $bookingModel->create([
            \'resource_id\'    => (int) $resource[\'id\'],
            \'package_id\'     => $actualPkgId,
            \'product_id\'     => $actualProdId,
            \'customer_name\'  => $name,
            \'customer_email\' => $email,
            \'customer_phone\' => $phone,
            \'booking_date\'   => $date,
            \'start_time\'     => $startTime,
            \'end_time\'       => $endTime,
            \'duration_mins\'  => $slotMins,
            \'pricing_type\'   => $pricingType,
            \'subtotal\'       => $subtotal,
            \'deposit_amount\' => $deposit,
            \'total_amount\'   => $subtotal,
            \'payment_status\' => \'none\',
            \'booking_status\' => $status,
            \'notes\'          => $notes,
            \'ip_address\'     => $req->ip(),
        ]);

        $booking = $bookingModel->findById($id);
        if ($booking) {
            $this->sendCustomerEmail($booking, $settings);
            $this->sendOwnerEmail($booking, $settings);
        }

        return (new Response())->redirect(\'/booking/confirmation/\' . ($booking[\'reference\'] ?? \'\'));
    }

    // ── Confirmation ──────────────────────────────────────────────────────────

    public function confirmation(Request $req, array $params): Response
    {
        $booking = (new Booking($this->pdo()))->findByReference($params[\'reference\']);
        if (!$booking) {
            return (new Response())->redirect(\'/booking\');
        }
        return $this->render(\'booking/confirm.php\', [
            \'booking\'  => $booking,
            \'settings\' => $this->settings(),
        ]);
    }

    // ── Email helpers ─────────────────────────────────────────────────────────

    private function sendCustomerEmail(array $booking, array $settings): void
    {
        $to      = $booking[\'customer_email\'];
        $subject = $settings[\'customer_email_subject\'] ?? \'Your Booking Confirmation\';
        $body    = $settings[\'customer_email_body\']    ?? \'Thank you for your booking.\';
        $body    = $this->replacePlaceholders($body, $booking);
        try {
            (new EmailQueue($this->pdo()))->enqueue($to, $subject, nl2br(e($body)));
        } catch (\\Throwable) {}
    }

    private function sendOwnerEmail(array $booking, array $settings): void
    {
        $to = $settings[\'notification_email\'] ?? \'\';
        if ($to === \'\') {
            return;
        }
        $subject = $settings[\'owner_email_subject\'] ?? \'New Booking Received\';
        $body    = $settings[\'owner_email_body\']    ?? \'A new booking has been made.\';
        $body    = $this->replacePlaceholders($body, $booking);
        try {
            (new EmailQueue($this->pdo()))->enqueue($to, $subject, nl2br(e($body)));
        } catch (\\Throwable) {}
    }

    private function replacePlaceholders(string $template, array $booking): string
    {
        $map = [
