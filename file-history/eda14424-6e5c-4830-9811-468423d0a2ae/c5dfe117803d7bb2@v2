write('modules/booking/models/BookingResource.php', '''<?php declare(strict_types=1);
namespace VeloCMS\\Modules\\Booking\\Models;

class BookingResource
{
    public function __construct(private readonly \\PDO $pdo) {}

    public function all(bool $activeOnly = false): array
    {
        $sql = 'SELECT * FROM booking_resources WHERE deleted_at IS NULL';
        if ($activeOnly) {
            $sql .= ' AND active = 1';
        }
        $sql .= ' ORDER BY sort_order ASC, name ASC';
        return $this->pdo->query($sql)->fetchAll();
    }

    public function findById(int $id): ?array
    {
        $stmt = $this->pdo->prepare(
            'SELECT * FROM booking_resources WHERE id = ? AND deleted_at IS NULL LIMIT 1'
        );
        $stmt->execute([$id]);
        return $stmt->fetch() ?: null;
    }

    public function findBySlug(string $slug): ?array
    {
        $stmt = $this->pdo->prepare(
            'SELECT * FROM booking_resources WHERE slug = ? AND deleted_at IS NULL LIMIT 1'
        );
        $stmt->execute([$slug]);
        return $stmt->fetch() ?: null;
    }

    public function create(array $data): int
    {
        $slug = $this->uniqueSlug($data[\'slug\'] !== \'\' ? $data[\'slug\'] : $this->slugify($data[\'name\']));
        $this->pdo->prepare(
            \'INSERT INTO booking_resources
              (name, slug, description, image, active, pricing_mode, hourly_rate,
               min_duration_mins, max_duration_mins, advance_booking_hours, sort_order)
             VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\'
        )->execute([
            $data[\'name\'], $slug,
            $data[\'description\'] ?? \'\',
            $data[\'image\'] ?? \'\',
            $data[\'active\'] ? 1 : 0,
            $data[\'pricing_mode\'],
            $data[\'hourly_rate\'] !== \'\' ? (float) $data[\'hourly_rate\'] : null,
            (int) $data[\'min_duration_mins\'],
            (int) $data[\'max_duration_mins\'],
            (int) $data[\'advance_booking_hours\'],
            (int) ($data[\'sort_order\'] ?? 0),
        ]);
        return (int) $this->pdo->lastInsertId();
    }

    public function update(int $id, array $data): void
    {
        $slug = $this->uniqueSlug(
            $data[\'slug\'] !== \'\' ? $data[\'slug\'] : $this->slugify($data[\'name\']),
            $id
        );
        $this->pdo->prepare(
            \'UPDATE booking_resources
             SET name=?, slug=?, description=?, image=?, active=?, pricing_mode=?,
                 hourly_rate=?, min_duration_mins=?, max_duration_mins=?,
                 advance_booking_hours=?, sort_order=?
             WHERE id=?\'
        )->execute([
            $data[\'name\'], $slug,
            $data[\'description\'] ?? \'\',
            $data[\'image\'] ?? \'\',
            $data[\'active\'] ? 1 : 0,
            $data[\'pricing_mode\'],
            $data[\'hourly_rate\'] !== \'\' ? (float) $data[\'hourly_rate\'] : null,
            (int) $data[\'min_duration_mins\'],
            (int) $data[\'max_duration_mins\'],
            (int) $data[\'advance_booking_hours\'],
            (int) ($data[\'sort_order\'] ?? 0),
            $id,
        ]);
    }

    public function softDelete(int $id): void
    {
        $this->pdo->prepare(
            \'UPDATE booking_resources SET deleted_at = NOW() WHERE id = ?\'
        )->execute([$id]);
    }

    private function slugify(string $text): string
    {
        $text = mb_strtolower($text);
        $text = preg_replace(\'/[^a-z0-9\\\\s-]/\', \'\', $text) ?? $text;
        return trim(preg_replace(\'/[\\\\s-]+/\', \'-\', $text) ?? $text, \'-\');
    }

    private function uniqueSlug(string $slug, int $excludeId = 0): string
    {
        $original = $slug;
        $i = 1;
        while (true) {
            $stmt = $this->pdo->prepare(
                \'SELECT id FROM booking_resources WHERE slug = ? AND id != ? AND deleted_at IS NULL LIMIT 1\'
            );
            $stmt->execute([$slug, $excludeId]);
            if (!$stmt->fetch()) {
                break;
            }
            $slug = $original . \'-\' . $i++;
        }
        return $slug;
    }
}
''')

