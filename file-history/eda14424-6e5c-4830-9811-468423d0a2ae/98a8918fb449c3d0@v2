namespace VeloCMS\Admin;

use VeloCMS\Core\Database;
use VeloCMS\Core\Request;
use VeloCMS\Core\Response;

class DashboardController extends BaseController
{
    public function index(Request $request, array $params): Response
    {
        $this->auth()->requireLogin();

        $db = $this->app->make(Database::class);

        $siteCount = (int) $db->core()
            ->query('SELECT COUNT(*) FROM sites WHERE status = "active"')
            ->fetchColumn();

        $userCount = (int) $db->core()
            ->query('SELECT COUNT(*) FROM users WHERE deleted_at IS NULL')
            ->fetchColumn();

        return $this->layout('dashboard.php', [
            'user'       => $this->auth()->user(),
            'page'       => 'dashboard',
            'siteCount'  => $siteCount,
            'userCount'  => $userCount,
            'phpVersion' => PHP_VERSION,
            'cmsVersion' => '0.1.0',
        ]);
    }
}
"""

