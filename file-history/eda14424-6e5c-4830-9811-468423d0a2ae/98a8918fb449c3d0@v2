files['admin/controllers/AuthController.php'] = r"""<?php declare(strict_types=1);
namespace VeloCMS\Admin;

use VeloCMS\Core\Request;
use VeloCMS\Core\Response;

class AuthController extends BaseController
{
    public function index(Request $request, array $params): Response
    {
        if ($this->auth()->check()) {
            return $this->redirect('/admin/dashboard');
        }
        return $this->redirect('/admin/login');
    }

    public function showLogin(Request $request, array $params): Response
    {
        if ($this->auth()->check()) {
            return $this->redirect('/admin/dashboard');
        }

        $html = $this->view('login.php', [
            'csrf'  => $this->auth()->csrfToken(),
            'error' => $_GET['error'] ?? null,
            'email' => $_GET['email'] ?? '',
        ]);
        return (new Response())->html($html);
    }

    public function processLogin(Request $request, array $params): Response
    {
        if (!$this->auth()->verifyCsrf()) {
            return $this->redirect('/admin/login?error=' . urlencode('Invalid request. Please try again.'));
        }

        $email    = trim($request->post('email', ''));
        $password = $request->post('password', '');

        if ($email === '' || $password === '') {
            return $this->redirect('/admin/login?error=' . urlencode('Email and password are required.')
                . '&email=' . urlencode($email));
        }

        try {
            $ok = $this->auth()->attempt($email, $password, $request->ip());
        } catch (\RuntimeException $e) {
            return $this->redirect('/admin/login?error=' . urlencode($e->getMessage())
                . '&email=' . urlencode($email));
        }

        if (!$ok) {
            return $this->redirect('/admin/login?error=' . urlencode('Incorrect email or password.')
                . '&email=' . urlencode($email));
        }

        return $this->redirect('/admin/dashboard');
    }

    public function logout(Request $request, array $params): Response
    {
        $this->auth()->logout();
        return $this->redirect('/admin/login');
    }
}
"""

