BASE = '/var/www/velocms'
import subprocess, os

def env():
    e = dict(os.environ)
    for line in open(BASE + '/.env'):
        line = line.strip()
        if '=' in line and not line.startswith('#'):
            k, v = line.split('=', 1)
            e[k] = v
    return e

def mysql(sql):
    ev = env()
    return subprocess.run(
        ['mysql', '-u', ev.get('CORE_DB_USER', 'velocms'),
         '-p' + ev.get('CORE_DB_PASS', ''), ev.get('CORE_DB_NAME', 'velocms'), '-e', sql],
        capture_output=True, text=True, env=ev
    )

def php_lint(path, label=''):
    r = subprocess.run(['php', '-l', path], capture_output=True, text=True)
    print(('OK ' if r.returncode == 0 else 'ERR') + f'  php -l {label or path}')
    if r.returncode != 0: print(r.stderr)

