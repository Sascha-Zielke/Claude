if not r.stdout.strip():
    r2 = mysql(
        "ALTER TABLE bookings "
        "ADD COLUMN end_date DATE DEFAULT NULL AFTER booking_date, "
        "ADD COLUMN nights SMALLINT UNSIGNED DEFAULT NULL AFTER end_date, "
        "MODIFY pricing_type ENUM('hourly','package','product','daily') NOT NULL DEFAULT 'hourly';"
