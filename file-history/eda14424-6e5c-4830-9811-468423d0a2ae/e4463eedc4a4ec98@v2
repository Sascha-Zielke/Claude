import os, re

base = '/var/www/velocms'
fixed = []

def write(rel, content):
    path = base + '/' + rel
    os.makedirs(os.path.dirname(path), exist_ok=True)
    open(path, 'w').write(content.lstrip('\n'))
    fixed.append(rel)
    print(f'  OK  {rel}')

def patch(rel, old, new, label=None):
    path = base + '/' + rel
    c = open(path).read()
    if old not in c:
        print(f'  SKIP {rel}: pattern not found ({label or old[:40]})')
        return False
    open(path, 'w').write(c.replace(old, new, 1))
    fixed.append(f'{rel} ({label})')
    print(f'  OK  {rel}: {label}')
    return True

def wrap_table(rel, label=None):
    """Wrap bare <table class="vcms-table"> in <div class="vcms-table-wrap">"""
    path = base + '/' + rel
    c = open(path).read()
    # Match table tags that are NOT already inside a vcms-table-wrap
    changed = False
    lines = c.splitlines(keepends=True)
    out = []
    i = 0
    while i < len(lines):
        line = lines[i]
        # Find lines with <table class="vcms-table" that don't already have a wrapper before them
        if '<table class="vcms-table"' in line:
            # Check if the previous non-empty line is already a table-wrap div
            prev = ''.join(out).rstrip()
            if 'vcms-table-wrap' not in prev.split('\n')[-1]:
                indent = len(line) - len(line.lstrip())
                out.append(' ' * indent + '<div class="vcms-table-wrap">\n')
                # Find the closing </table> and append </div> after it
                depth = 0
                buf = [line]
                j = i + 1
                while j < len(lines):
                    buf.append(lines[j])
                    if '<table' in lines[j]:
                        depth += 1
                    if '</table>' in lines[j]:
                        if depth == 0:
                            out.extend(buf)
                            out.append(' ' * indent + '</div>\n')
                            i = j + 1
                            changed = True
                            break
                        depth -= 1
                    j += 1
                else:
                    out.extend(buf)
                    i = j
                continue
        out.append(line)
        i += 1
    if changed:
        open(path, 'w').write(''.join(out))
        fixed.append(f'{rel} (table wrapped)')
        print(f'  OK  {rel}: tables wrapped in vcms-table-wrap')
    else:
        print(f'  SKIP {rel}: already wrapped or pattern not found')

