print('\nSTEP 4 — Wrap bare tables in vcms-table-wrap')
# ═══════════════════════════════════════════════════════════════════════════════

tables_to_wrap = [
    'admin/views/forms/index.php',
    'admin/views/forms/submissions.php',
    'admin/views/seo/index.php',
    'admin/views/blog/categories.php',
    'admin/views/api/index.php',
    'admin/views/navigation/index.php',
    'admin/views/navigation/edit.php',
    'admin/views/audit/index.php',
    'admin/views/cron/index.php',
]

for rel in tables_to_wrap:
    path = base + '/' + rel
    c = open(path).read()
    # Only wrap if not already wrapped
    if 'vcms-table-wrap' in c:
        print(f'  SKIP {rel}: already has vcms-table-wrap')
        continue
    # Wrap every <table class="vcms-table"> that isn't already inside a wrapper
    new_c = re.sub(
        r'(<table class="vcms-table")',
        r'<div class="vcms-table-wrap">\n\1',
        c
    )
    new_c = re.sub(
        r'(</table>)(?!\s*</div)',
        r'\1\n</div>',
        new_c
    )
    if new_c != c:
        open(path, 'w').write(new_c)
        fixed.append(f'{rel} (table wrapped)')
        print(f'  OK  {rel}: table wrapped')
    else:
        print(f'  SKIP {rel}: regex did not match')

