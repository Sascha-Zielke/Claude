files['modules/seo/models/Redirect.php'] = r"""<?php declare(strict_types=1);
namespace VeloCMS\Modules\Seo\Models;

class Redirect
{
    public function __construct(private readonly \PDO $pdo) {}

    public function all(): array
    {
        return $this->pdo->query(
            'SELECT * FROM redirects ORDER BY created_at DESC'
        )->fetchAll();
    }

    public function findByPath(string $path): ?array
    {
        $stmt = $this->pdo->prepare('SELECT * FROM redirects WHERE from_path = ? LIMIT 1');
        $stmt->execute([$path]);
        return $stmt->fetch() ?: null;
    }

    public function create(string $from, string $to, int $code): void
    {
        $this->pdo->prepare(
            'INSERT INTO redirects (from_path, to_url, code) VALUES (?, ?, ?)
             ON DUPLICATE KEY UPDATE to_url = VALUES(to_url), code = VALUES(code)'
        )->execute([$from, $to, $code]);
    }

    public function delete(int $id): void
    {
        $this->pdo->prepare('DELETE FROM redirects WHERE id = ?')->execute([$id]);
    }
}
"""

# ── modules/seo/controllers/SitemapController.php ────────────────────────────
files['modules/seo/controllers/SitemapController.php'] = r"""<?php declare(strict_types=1);
namespace VeloCMS\Modules\Seo\Controllers;

use VeloCMS\Core\Application;
use VeloCMS\Core\Database;
use VeloCMS\Core\Request;
use VeloCMS\Core\Response;

class SitemapController
{
    public function __construct(private readonly Application $app) {}

    public function index(Request $request, array $params): Response
    {
        $db  = $this->app->make(Database::class)->core();
        $xml = new \SimpleXMLElement(
            '<?xml version="1.0" encoding="UTF-8"?>'
            . '<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"/>'
        );

        $baseUrl = rtrim($request->header('X-Forwarded-Proto', 'http')
            . '://' . $request->host(), '/');

        // Published pages
        $pages = $db->query(
            "SELECT slug, updated_at FROM pages WHERE status='published' AND deleted_at IS NULL"
        )->fetchAll();
        foreach ($pages as $page) {
            $url = $xml->addChild('url');
            $url->addChild('loc', e($baseUrl . '/' . $page['slug']));
            $url->addChild('lastmod', substr($page['updated_at'], 0, 10));
            $url->addChild('changefreq', 'weekly');
            $url->addChild('priority', '0.8');
        }

        // Published posts
        $posts = $db->query(
            "SELECT slug, updated_at FROM posts WHERE status='published' AND deleted_at IS NULL"
        )->fetchAll();
        foreach ($posts as $post) {
            $url = $xml->addChild('url');
            $url->addChild('loc', e($baseUrl . '/blog/' . $post['slug']));
            $url->addChild('lastmod', substr($post['updated_at'], 0, 10));
            $url->addChild('changefreq', 'monthly');
            $url->addChild('priority', '0.6');
        }

        return (new Response())
            ->withHeader('Content-Type', 'application/xml; charset=UTF-8')
            ->html($xml->asXML() ?: '');
    }
}
"""

