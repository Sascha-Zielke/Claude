namespace VeloCMS\Modules\Seo\Controllers;

use VeloCMS\Core\Application;
use VeloCMS\Core\Request;
use VeloCMS\Core\Response;

class RobotsController
{
    public function __construct(private readonly Application $app) {}

    public function index(Request $request, array $params): Response
    {
        $host    = $request->host();
        $proto   = $request->header('X-Forwarded-Proto', 'http');
        $baseUrl = $proto . '://' . $host;

        $content = "User-agent: *\nAllow: /\n\nSitemap: {$baseUrl}/sitemap.xml\n";

        return (new Response())
            ->withHeader('Content-Type', 'text/plain; charset=UTF-8')
            ->html($content);
    }
}
"""

