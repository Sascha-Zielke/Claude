files['modules/seo/admin/controllers/RedirectAdminController.php'] = r"""<?php declare(strict_types=1);
namespace VeloCMS\Modules\Seo\Admin;

use VeloCMS\Admin\BaseController;
use VeloCMS\Core\Database;
use VeloCMS\Core\Request;
use VeloCMS\Core\Response;
use VeloCMS\Modules\Seo\Models\Redirect;

class RedirectAdminController extends BaseController
{
    private function model(): Redirect
    {
        return new Redirect($this->app->make(Database::class)->core());
    }

    public function index(Request $req, array $params): Response
    {
        $this->auth()->requireRole('superadmin', 'site-admin');
        return $this->layout('seo/index.php', [
            'user'      => $this->auth()->user(),
            'page'      => 'seo',
            'csrf'      => $this->auth()->csrfToken(),
            'redirects' => $this->model()->all(),
            'error'     => null,
        ]);
    }

    public function store(Request $req, array $params): Response
    {
        $this->auth()->requireRole('superadmin', 'site-admin');
        if (!$this->auth()->verifyCsrf()) return $this->redirect('/admin/seo');
        $from = trim($req->post('from_path', ''));
        $to   = trim($req->post('to_url', ''));
        $code = (int) $req->post('code', '301');
        if ($from !== '' && $to !== '') {
            $this->model()->create($from, $to, in_array($code, [301, 302]) ? $code : 301);
        }
        return $this->redirect('/admin/seo');
    }

    public function delete(Request $req, array $params): Response
    {
        $this->auth()->requireRole('superadmin', 'site-admin');
        if (!$this->auth()->verifyCsrf()) return $this->redirect('/admin/seo');
        $this->model()->delete((int) $params['id']);
        return $this->redirect('/admin/seo');
    }
}
"""

