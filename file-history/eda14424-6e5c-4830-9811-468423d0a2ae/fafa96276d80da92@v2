files['tests/Unit/HelpersTest.php'] = r"""<?php declare(strict_types=1);

use PHPUnit\Framework\TestCase;

class HelpersTest extends TestCase
{
    // ── slug() ───────────────────────────────────────────────────────────────

    public function test_slug_lowercases_and_replaces_spaces(): void
    {
        $this->assertSame('hello-world', slug('Hello World'));
    }

    public function test_slug_collapses_multiple_hyphens(): void
    {
        $this->assertSame('a-b-c', slug('a -- b -- c'));
    }

    public function test_slug_trims_leading_and_trailing_hyphens(): void
    {
        $this->assertSame('hello', slug('-hello-'));
    }

    public function test_slug_empty_string(): void
    {
        $this->assertSame('', slug(''));
    }

    public function test_slug_numbers_preserved(): void
    {
        $this->assertSame('phase-6b-test', slug('Phase 6b Test'));
    }

    // ── excerpt() ────────────────────────────────────────────────────────────

    public function test_excerpt_strips_html_tags(): void
    {
        $result = excerpt('<p>Hello <strong>World</strong></p>', 100);
        $this->assertStringNotContainsString('<', $result);
        $this->assertStringContainsString('Hello World', $result);
    }

    public function test_excerpt_truncates_to_length(): void
    {
        $text = str_repeat('a', 300);
        $result = excerpt($text, 100);
        $this->assertLessThanOrEqual(103, strlen($result)); // 100 + '...'
    }

    public function test_excerpt_does_not_truncate_short_text(): void
    {
        $result = excerpt('<p>Short text</p>', 200);
        $this->assertSame('Short text', $result);
    }

    public function test_excerpt_appends_ellipsis_when_truncated(): void
    {
        $text = str_repeat('b', 300);
        $result = excerpt($text, 50);
        $this->assertStringEndsWith('...', $result);
    }

    // ── e() ─────────────────────────────────────────────────────────────────

    public function test_e_escapes_script_tag(): void
    {
        $this->assertSame('&lt;script&gt;alert(1)&lt;/script&gt;', e('<script>alert(1)</script>'));
    }

    public function test_e_handles_ampersand(): void
    {
        $this->assertSame('Tom &amp; Jerry', e('Tom & Jerry'));
    }

    public function test_e_handles_quotes(): void
    {
        $this->assertSame('say &quot;hi&quot;', e('say "hi"'));
    }

    // ── date_fmt() ───────────────────────────────────────────────────────────

    public function test_date_fmt_formats_timestamp(): void
    {
        $result = date_fmt('2026-01-15 12:00:00', 'Y-m-d');
        $this->assertSame('2026-01-15', $result);
    }

    public function test_date_fmt_returns_empty_for_null(): void
    {
        $this->assertSame('', date_fmt(null));
    }

    public function test_date_fmt_returns_empty_for_empty_string(): void
    {
        $this->assertSame('', date_fmt(''));
    }
}
