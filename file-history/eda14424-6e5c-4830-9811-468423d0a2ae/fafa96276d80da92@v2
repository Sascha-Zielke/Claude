files['tests/Unit/AuditLogTest.php'] = r"""<?php declare(strict_types=1);

use PHPUnit\Framework\TestCase;
use VeloCMS\Modules\Audit\Models\AuditLog;

class AuditLogTest extends TestCase
{
    private PDO $pdo;

    protected function setUp(): void
    {
        $this->pdo = new PDO(
            'mysql:host=' . ($_ENV['CORE_DB_HOST'] ?? '127.0.0.1')
            . ';dbname=' . ($_ENV['CORE_DB_NAME'] ?? 'velocms_core')
            . ';charset=utf8mb4',
            $_ENV['CORE_DB_USER'] ?? 'velocms',
            $_ENV['CORE_DB_PASS'] ?? '',
            [PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION]
        );
    }

    public function test_write_inserts_row(): void
    {
        $before = (int)$this->pdo->query('SELECT COUNT(*) FROM audit_log')->fetchColumn();

        AuditLog::write(
            $this->pdo,
            null,
            'PHPUNIT_TEST',
            'unit_test',
            null,
            ['note' => 'phpunit'],
            '127.0.0.1'
        );

        $after = (int)$this->pdo->query('SELECT COUNT(*) FROM audit_log')->fetchColumn();
        $this->assertSame($before + 1, $after);
    }

    public function test_write_stores_correct_action(): void
    {
        AuditLog::write($this->pdo, null, 'PHPUNIT_ACTION_CHECK', 'test', null, [], '10.0.0.1');

        $row = $this->pdo
            ->query("SELECT action FROM audit_log WHERE action='PHPUNIT_ACTION_CHECK' ORDER BY id DESC LIMIT 1")
            ->fetch(PDO::FETCH_ASSOC);

        $this->assertSame('PHPUNIT_ACTION_CHECK', $row['action']);
    }

    public function test_prune_removes_old_rows(): void
    {
        $this->pdo->exec(
            "INSERT INTO audit_log (user_id, action, entity_type, entity_id, meta, ip, created_at)
             VALUES (NULL, 'PHPUNIT_OLD', NULL, NULL, '{}', '1.2.3.4', DATE_SUB(NOW(), INTERVAL 100 DAY))"
        );

        $pruned = AuditLog::prune($this->pdo, 90);
        $this->assertGreaterThanOrEqual(1, $pruned);
    }
}
"""

