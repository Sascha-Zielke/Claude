files['tests/Unit/ResponseTest.php'] = r"""<?php declare(strict_types=1);

use PHPUnit\Framework\TestCase;
use VeloCMS\Core\Response;

class ResponseTest extends TestCase
{
    public function test_default_status_is_200(): void
    {
        $r = new Response();
        $this->assertSame(200, $r->getStatus());
    }

    public function test_status_can_be_set(): void
    {
        $r = (new Response())->status(404);
        $this->assertSame(404, $r->getStatus());
    }

    public function test_body_can_be_set(): void
    {
        $r = (new Response())->body('hello');
        $this->assertSame('hello', $r->getBody());
    }

    public function test_json_response_encodes_array(): void
    {
        $r = Response::json(['ok' => true]);
        $this->assertSame(200, $r->getStatus());
        $decoded = json_decode($r->getBody(), true);
        $this->assertTrue($decoded['ok']);
    }

    public function test_json_response_with_custom_status(): void
    {
        $r = Response::json(['error' => 'not found'], 404);
        $this->assertSame(404, $r->getStatus());
    }
}
"""

