        ctrl = ctrl.replace(old_validate_dates, new_validate_dates)
        print('OK  BookingAdminController::createStore() — date validation added')
    else:
        print('ERR BookingAdminController::createStore() — validation pattern not found')
else:
    print('SKIP BookingAdminController::createStore() — already updated')

