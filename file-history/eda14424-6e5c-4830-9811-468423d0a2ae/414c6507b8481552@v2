)

if "catch (\\Throwable $e)" not in ctrl or "'Booking create error'" not in ctrl:
    if old_create_call in ctrl:
        ctrl = ctrl.replace(old_create_call, new_create_call)
        print('OK  BookingAdminController::createStore() — try/catch added')
    else:
        print('ERR BookingAdminController::createStore() — create call pattern not found')
else:
    print('SKIP BookingAdminController::createStore() — try/catch already present')

