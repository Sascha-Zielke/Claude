"""vcms_s14c_validation.py
Fix 3 — Date/time validation:
  - admin/views/booking/create.php: client-side end-time min + inline error
  - BookingAdminController::createForm(): pass $settings to view
  - BookingAdminController::createStore(): server-side end>start + try/catch
  - BookingController::bookStore(): server-side validation + try/catch
"""
BASE = '/var/www/velocms'
import subprocess

def php_lint(path, label=''):
    r = subprocess.run(['php', '-l', path], capture_output=True, text=True)
    print(('OK ' if r.returncode == 0 else 'ERR') + f'  php -l {label or path}')
    if r.returncode != 0: print(r.stderr)

# ── 1. admin create.php — client-side time validation ────────────────────────
create_path = BASE + '/admin/views/booking/create.php'
create = open(create_path).read()

# a) Add time-error paragraph after the hourly date row
old_hourly_row = (
    "    <!-- Daily: check-in / check-out dates -->"
)
new_hourly_row = (
    "    <p id=\"b-time-err\" style=\"display:none;color:#dc2626;font-size:.875rem;margin:.25rem 0 .5rem\">End time must be after start time.</p>\n"
    "\n"
    "    <!-- Daily: check-in / check-out dates -->"
)

# b) Replace the existing JS block to add validation
old_js = (
    "function togglePricingFields() {\n"
    "    const type = document.getElementById('b-pricing').value;\n"
    "    document.getElementById('pkg-field').style.display      = type === 'package' ? '' : 'none';\n"
    "    document.getElementById('prod-field').style.display     = type === 'product' ? '' : 'none';\n"
    "    document.getElementById('hourly-date-row').style.display = type === 'daily'   ? 'none' : '';\n"
    "    document.getElementById('daily-date-row').style.display  = type === 'daily'   ? '' : 'none';\n"
    "}"
)
new_js = (
    "function togglePricingFields() {\n"
    "    const type = document.getElementById('b-pricing').value;\n"
    "    document.getElementById('pkg-field').style.display       = type === 'package' ? '' : 'none';\n"
    "    document.getElementById('prod-field').style.display      = type === 'product' ? '' : 'none';\n"
    "    document.getElementById('hourly-date-row').style.display  = type === 'daily'   ? 'none' : '';\n"
    "    document.getElementById('daily-date-row').style.display   = type === 'daily'   ? '' : 'none';\n"
    "    document.getElementById('b-time-err').style.display = 'none';\n"
    "}\n"
    "\n"
    "function validateHourlyTime() {\n"
    "    const start = document.getElementById('b-start').value;\n"
    "    const end   = document.getElementById('b-end').value;\n"
    "    const err   = document.getElementById('b-time-err');\n"
    "    const btn   = document.querySelector('#manual-booking-form button[type=submit]');\n"
    "    const bad   = start && end && end <= start;\n"
    "    err.style.display = bad ? '' : 'none';\n"
    "    if (btn) btn.disabled = !!bad;\n"
    "    if (start) document.getElementById('b-end').min = start;\n"
    "}\n"
    "\n"
    "document.getElementById('b-start').addEventListener('change', validateHourlyTime);\n"
    "document.getElementById('b-end').addEventListener('change', validateHourlyTime);"
)

changed = 0
for old, new, label in [
    (old_hourly_row, new_hourly_row, 'time-error paragraph'),
    (old_js,         new_js,         'JS validation'),
]:
    if old in create:
        create = create.replace(old, new)
        changed += 1
        print(f'OK  create.php — {label}')
    elif 'validateHourlyTime' in create and label == 'JS validation':
        print(f'SKIP create.php — {label} already present')
    else:
        print(f'ERR create.php — pattern not found for {label}')

with open(create_path, 'w') as f: f.write(create)
php_lint(create_path, 'admin/views/booking/create.php')

