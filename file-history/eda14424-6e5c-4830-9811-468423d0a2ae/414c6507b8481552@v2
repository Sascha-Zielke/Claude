        "            'end_date'       => $endDate,\n"
        "            'nights'         => $nights,\n"
        "            'start_time'     => $startTime,\n"
        "            'end_time'       => $endTime,\n"
        "            'duration_mins'  => $duration,\n"
        "            'pricing_type'   => $pricingType,\n"
