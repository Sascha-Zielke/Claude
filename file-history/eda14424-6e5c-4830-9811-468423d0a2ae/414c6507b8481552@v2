        "            if (!preg_match('/^\\d{4}-\\d{2}-\\d{2}$/', $checkinDate)) {\n"
        "                $errors[] = 'Please select a check-in date.';\n"
        "            }\n"
        "            if (!preg_match('/^\\d{4}-\\d{2}-\\d{2}$/', $checkoutDate)) {\n"
        "                $errors[] = 'Please select a check-out date.';\n"
        "            }\n"
        "        } else {\n"
        "            if (!preg_match('/^\\d{4}-\\d{2}-\\d{2}$/', $date)) {\n"
        "                $errors[] = 'Please select a date.';\n"
        "            }\n"
        "            if (!preg_match('/^\\d{2}:\\d{2}$/', $startTime)) {\n"
        "                $errors[] = 'Please select a start time.';\n"
        "            }\n"
        "        }"
)
new_store_validate = (
        "        $errors = [];\n"
        "        if ($name === '') {\n"
        "            $errors[] = 'Name is required.';\n"
        "        }\n"
        "        if (!filter_var($email, FILTER_VALIDATE_EMAIL)) {\n"
        "            $errors[] = 'A valid email address is required.';\n"
        "        }\n"
        "        if ($pricingType === 'daily') {\n"
        "            if (!preg_match('/^\\d{4}-\\d{2}-\\d{2}$/', $checkinDate)) {\n"
        "                $errors[] = 'Please select a check-in date.';\n"
        "            } elseif (!preg_match('/^\\d{4}-\\d{2}-\\d{2}$/', $checkoutDate)) {\n"
