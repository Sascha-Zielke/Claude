<script>
function toggleHourlyRate() {
    const mode  = document.getElementById('r-pricing').value;
    document.getElementById('hourly-rate-group').style.display = (mode === 'hourly' || mode === 'combined') ? '' : 'none';
    document.getElementById('daily-rate-group').style.display  = (mode === 'daily'  || mode === 'combined') ? '' : 'none';
}
toggleHourlyRate();

var slugInput  = document.getElementById('r-slug');
var nameInput  = document.getElementById('r-name');
var slugManual = slugInput ? (slugInput.dataset.manual === '1') : false;

if (slugInput && nameInput) {
    slugInput.addEventListener('input', function () {
        slugManual = true;
        slugInput.dataset.manual = '1';
    });
    nameInput.addEventListener('input', function () {
        if (slugManual) return;
        var slug = nameInput.value
            .toLowerCase()
            .replace(/[^a-z0-9\s-]/g, '')
            .trim()
            .replace(/[\s]+/g, '-')
            .replace(/-+/g, '-');
        slugInput.value = slug;
    });
}
</script>
