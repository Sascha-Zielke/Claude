                $tzCurrent = $bk['timezone'] ?? 'Europe/Berlin';
                $tzAll     = DateTimeZone::listIdentifiers();
                $tzEurope  = array_filter($tzAll, fn($z) => str_starts_with($z, 'Europe/'));
                $tzOther   = array_filter($tzAll, fn($z) => !str_starts_with($z, 'Europe/'));
                sort($tzEurope); sort($tzOther);
                $tzEuropeSorted = array_merge(
                    ['Europe/Berlin'],
                    array_values(array_filter($tzEurope, fn($z) => $z !== 'Europe/Berlin'))
                );
                function renderTzOption(string $tz, string $current): string {
                    try {
                        $offset  = (new DateTimeZone($tz))->getOffset(new DateTime('now', new DateTimeZone($tz)));
                        $sign    = $offset >= 0 ? '+' : '-';
                        $h       = abs((int)($offset / 3600));
                        $m       = abs((int)(($offset % 3600) / 60));
                        $label   = $tz . ' (GMT' . $sign . $h . ($m ? ':' . str_pad($m,2,'0',STR_PAD_LEFT) : '') . ')';
                    } catch (\Exception $e) {
                        $label = $tz;
                    }
                    $sel = $tz === $current ? ' selected' : '';
                    return '<option value="' . e($tz) . '"' . $sel . '>' . e($label) . '</option>';
                }
                ?>
                <select id="bk-tz" name="timezone">
                    <optgroup label="Europe">
                    <?php foreach ($tzEuropeSorted as $tz): ?>
                        <?= renderTzOption($tz, $tzCurrent) ?>
                    <?php endforeach ?>
                    </optgroup>
                    <optgroup label="Other">
                    <?php foreach ($tzOther as $tz): ?>
                        <?= renderTzOption($tz, $tzCurrent) ?>
                    <?php endforeach ?>
                    </optgroup>
