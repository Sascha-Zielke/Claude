<script>
(function () {
    const cal = document.getElementById('booking-calendar');
    if (!cal) return;
    const resource = cal.dataset.resource;
    const slotMins = parseInt(cal.dataset.slotMins, 10) || 60;
    const today    = new Date();
    let viewYear   = today.getFullYear();
    let viewMonth  = today.getMonth();

    const MONTHS = <?= json_encode([
        t('month.jan','Januar'), t('month.feb','Februar'), t('month.mar','März'),
        t('month.apr','April'),  t('month.may','Mai'),     t('month.jun','Juni'),
        t('month.jul','Juli'),   t('month.aug','August'),  t('month.sep','September'),
        t('month.oct','Oktober'),t('month.nov','November'),t('month.dec','Dezember'),
    ]) ?>;
    const DAYS = <?= json_encode([
        t('day.mo','Mo'), t('day.tu','Di'), t('day.we','Mi'),
        t('day.th','Do'), t('day.fr','Fr'), t('day.sa','Sa'), t('day.su','So'),
    ]) ?>;
    const MSG_LOADING = <?= json_encode(t('booking.loading', 'Lädt…')) ?>;
    const MSG_NO_SLOTS = <?= json_encode(t('booking.no_slots', 'Keine Verfügbarkeit an diesem Tag.')) ?>;
    const MSG_ERROR = <?= json_encode(t('booking.slots_error', 'Fehler beim Laden der Zeiten.')) ?>;

    function pad(n) { return String(n).padStart(2, '0'); }
    function fmtDate(y, m, d) { return `${y}-${pad(m+1)}-${pad(d)}`; }

    function renderCalendar(year, month) {
        const firstDay  = new Date(year, month, 1).getDay();
        const daysInMon = new Date(year, month + 1, 0).getDate();
        const startOfWeek = (firstDay === 0) ? 6 : firstDay - 1;

        let html = `<div class="cal-header">
            <button class="cal-nav" id="cal-prev">‹</button>
            <span class="cal-title">${MONTHS[month]} ${year}</span>
            <button class="cal-nav" id="cal-next">›</button>
        </div>
        <div class="cal-grid">`;
        DAYS.forEach(d => { html += `<div class="cal-dow">${d}</div>`; });

        for (let i = 0; i < startOfWeek; i++) html += '<div class="cal-cell cal-empty"></div>';
        const todayStr = fmtDate(today.getFullYear(), today.getMonth(), today.getDate());
        for (let d = 1; d <= daysInMon; d++) {
            const dateStr = fmtDate(year, month, d);
            const isPast  = dateStr < todayStr;
            html += isPast
                ? `<div class="cal-cell cal-past">${d}</div>`
                : `<button class="cal-cell cal-avail" data-date="${dateStr}">${d}</button>`;
        }
        html += '</div>';
        cal.innerHTML = html;

        document.getElementById('cal-prev').addEventListener('click', () => {
            viewMonth--; if (viewMonth < 0) { viewMonth = 11; viewYear--; }
            renderCalendar(viewYear, viewMonth);
        });
        document.getElementById('cal-next').addEventListener('click', () => {
            viewMonth++; if (viewMonth > 11) { viewMonth = 0; viewYear++; }
            renderCalendar(viewYear, viewMonth);
        });
        cal.querySelectorAll('.cal-avail').forEach(btn => {
            btn.addEventListener('click', () => loadSlots(btn.dataset.date));
        });
    }

    function loadSlots(date) {
        const slotsDiv  = document.getElementById('booking-slots');
        const slotsHead = document.getElementById('booking-slots-heading');
        const slotsList = document.getElementById('booking-slots-list');
        slotsHead.textContent = date;
        slotsList.innerHTML   = `<p>${MSG_LOADING}</p>`;
        slotsDiv.style.display = '';
        slotsDiv.scrollIntoView({ behavior: 'smooth' });

        fetch(`/booking/${resource}/availability?date=${date}`)
            .then(r => r.json())
            .then(data => {
                if (!data.slots || data.slots.length === 0) {
                    slotsList.innerHTML = `<p class="booking-no-slots">${MSG_NO_SLOTS}</p>`;
                    return;
                }
                slotsList.innerHTML = data.slots.map(s =>
                    `<a href="/booking/${resource}/book?date=${date}&start=${s.start}&pricing_type=hourly"
                        class="booking-slot-btn">${s.start} – ${s.end}</a>`
                ).join('');
            })
            .catch(() => { slotsList.innerHTML = `<p>${MSG_ERROR}</p>`; });
    }

    renderCalendar(viewYear, viewMonth);
}());
</script>
