<script>
const resourceData = <?= json_encode(array_column($resources, null, 'id')) ?>;

function togglePricingFields() {
    const type = document.getElementById('b-pricing').value;
    document.getElementById('pkg-field').style.display       = type === 'package' ? '' : 'none';
    document.getElementById('prod-field').style.display      = type === 'product' ? '' : 'none';
    document.getElementById('hourly-date-row').style.display  = type === 'daily'   ? 'none' : '';
    document.getElementById('daily-date-row').style.display   = type === 'daily'   ? '' : 'none';
    document.getElementById('b-time-err').style.display = 'none';
    const de = document.getElementById('b-date-err');
    if (de) de.style.display = 'none';
    const btn = document.querySelector('#manual-booking-form button[type=submit]');
    if (btn) btn.disabled = false;
}

function validateHourlyTime() {
    const start = document.getElementById('b-start').value;
    const end   = document.getElementById('b-end').value;
    const err   = document.getElementById('b-time-err');
    const btn   = document.querySelector('#manual-booking-form button[type=submit]');
    const bad   = start && end && end <= start;
    err.style.display = bad ? '' : 'none';
    if (btn) btn.disabled = !!bad;
}

document.getElementById('b-start').addEventListener('change', validateHourlyTime);
document.getElementById('b-end').addEventListener('change', validateHourlyTime);

function updateDailySummary() {
    const checkin  = document.getElementById('b-checkin').value;
    const checkout = document.getElementById('b-checkout').value;
    const summary  = document.getElementById('b-daily-summary');
    if (!checkin || !checkout) { summary.textContent = <?= json_encode(t('booking.select_dates', 'Daten auswählen')) ?>; return; }
    const nights = Math.round((new Date(checkout) - new Date(checkin)) / 86400000);
    if (nights < 1) { summary.textContent = <?= json_encode(t('booking.checkout_after_checkin', 'Abreise muss nach Anreise liegen')) ?>; return; }
    const res = resourceData[document.getElementById('b-resource').value];
    const rate = res && res.daily_rate ? parseFloat(res.daily_rate) : 0;
    const total = (rate * nights).toFixed(2);
    summary.textContent = nights + ' ' + (nights !== 1 ? <?= json_encode(t('booking.nights','Nächte')) ?> : <?= json_encode(t('booking.night','Nacht')) ?>) + (rate ? ' — Total: €' + total : '');
    document.getElementById('b-checkout').min = new Date(new Date(checkin).getTime() + 86400000).toISOString().slice(0,10);
}

function validateDailyDates() {
    const checkin  = document.getElementById('b-checkin').value;
    const checkout = document.getElementById('b-checkout').value;
    const err = document.getElementById('b-date-err');
    const btn = document.querySelector('#manual-booking-form button[type=submit]');
    if (checkin) {
        document.getElementById('b-checkout').min =
            new Date(new Date(checkin).getTime() + 86400000).toISOString().slice(0,10);
    }
    const bad = checkin && checkout && checkout <= checkin;
    if (err) err.style.display = bad ? '' : 'none';
    if (btn) btn.disabled = !!bad;
}

document.getElementById('b-checkin').addEventListener('change', function() { validateDailyDates(); updateDailySummary(); });
document.getElementById('b-checkout').addEventListener('change', function() { validateDailyDates(); updateDailySummary(); });

function loadResourceOptions(resourceId) {
    const pkgSel  = document.getElementById('b-package');
    const prodSel = document.getElementById('b-product');
    pkgSel.innerHTML  = '<option value=""><?= e(t('booking.none', '— keine —')) ?></option>';
    prodSel.innerHTML = '<option value=""><?= e(t('booking.none', '— keine —')) ?></option>';
    if (!resourceId) return;
    fetch(`/booking-admin-data/resource/${resourceId}/options`)
        .then(r => r.ok ? r.json() : null)
        .then(data => {
            if (!data) return;
            (data.packages || []).forEach(p => {
                pkgSel.innerHTML  += `<option value="${p.id}">${p.name} — €${p.price} (${p.duration_mins} min)</option>`;
            });
            (data.products || []).forEach(p => {
                prodSel.innerHTML += `<option value="${p.id}">${p.name} — €${p.price}</option>`;
            });
        });
}
</script>
""")

