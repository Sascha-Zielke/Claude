/* Farbige Boxen für Ordner in der Sidebar */

/* Basis-Styling für alle Ordner */
.nav-folder-title {
  border-radius: 6px !important;
  margin: 4px 4px !important;
  padding: 8px 10px !important;
  transition: all 0.2s ease !important;
}

/* 00 Kontext - Dunkelblau */
.nav-folder-title:has-text("00 Kontext") {
  background-color: rgba(41, 98, 255, 0.2) !important;
  color: #2962ff !important;
  font-weight: 600 !important;
}

/* 01 Inbox - Gelb */
.nav-folder-title:has-text("01 Inbox") {
  background-color: rgba(255, 193, 7, 0.2) !important;
  color: #ffc107 !important;
  font-weight: 600 !important;
}

/* 02 Projekte - Grün */
.nav-folder-title:has-text("02 Projekte") {
  background-color: rgba(76, 175, 80, 0.2) !important;
  color: #4caf50 !important;
  font-weight: 600 !important;
}

/* 03 Bereiche - Cyan */
.nav-folder-title:has-text("03 Bereiche") {
  background-color: rgba(0, 188, 212, 0.2) !important;
  color: #00bcd4 !important;
  font-weight: 600 !important;
}

/* 04 Ressourcen - Violett */
.nav-folder-title:has-text("04 Ressourcen") {
  background-color: rgba(156, 39, 176, 0.2) !important;
  color: #9c27b0 !important;
  font-weight: 600 !important;
}

/* 05 Daily Notes - Orange */
.nav-folder-title:has-text("05 Daily Notes") {
  background-color: rgba(255, 152, 0, 0.2) !important;
  color: #ff9800 !important;
  font-weight: 600 !important;
}

/* 06 Archiv - Grau */
.nav-folder-title:has-text("06 Archiv") {
  background-color: rgba(158, 158, 158, 0.2) !important;
  color: #9e9e9e !important;
  font-weight: 600 !important;
}

/* 07 Anhänge - Rot */
.nav-folder-title:has-text("07 Anhänge") {
  background-color: rgba(244, 67, 54, 0.2) !important;
  color: #f44336 !important;
  font-weight: 600 !important;
}

/* Life OS - Violett */
.nav-folder-title:has-text("Life OS") {
  background-color: rgba(103, 58, 183, 0.2) !important;
  color: #673ab7 !important;
  font-weight: 600 !important;
}

/* Unterordner etwas heller */
.nav-folder-title[style*="padding-left"] {
  opacity: 0.9 !important;
}