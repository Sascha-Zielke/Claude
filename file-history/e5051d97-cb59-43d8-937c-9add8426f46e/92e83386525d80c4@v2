# veloCMS — Architecture Guard

**Ziel:** Claude Code muss folgende bewährte Muster WIEDERHOLEN, nicht experimentieren.

Dieses Dokument ist die **Wahrheit** für veloCMS-Entwicklung. Abweichungen führen zu Crashes.

---

## ✅ BEWÄHRTE PATTERN (Diese funktionieren)

### Module-Struktur

Jedes Modul folgt diesem Aufbau:

```
velocms/modules/[ModuleName]/
├── [ModuleName]Module.php         (Modul-Bootstrapper)
├── Controllers/
│   ├── Admin[ModuleName]Controller.php
│   └── [ModuleName]Controller.php   (Frontend, falls benötigt)
├── Models/
│   └── [ModuleName]Model.php
├── migrations/
│   ├── 001_create_[table]_table.php
│   └── 002_...php
└── views/
    ├── admin/
    │   ├── index.php
    │   └── edit.php
    └── frontend/
        └── index.php
```

### Module-Klasse (Base Pattern)

```php
<?php
declare(strict_types=1);

namespace VeloCMS\Modules\[ModuleName];

use VeloCMS\Core\Module;

class [ModuleName]Module extends Module
{
    public string $name    = '[ModuleName]';
    public string $version = '1.0.0';

    public function boot(): void
    {
        // Admin routes
        $this->router->get('/admin/[slug]',              '[ModuleName]\Controllers\Admin[ModuleName]Controller@index');
        $this->router->get('/admin/[slug]/new',          '[ModuleName]\Controllers\Admin[ModuleName]Controller@new');
        $this->router->post('/admin/[slug]/save',        '[ModuleName]\Controllers\Admin[ModuleName]Controller@save');
        $this->router->get('/admin/[slug]/edit/[i:id]',  '[ModuleName]\Controllers\Admin[ModuleName]Controller@edit');
        $this->router->post('/admin/[slug]/update/[i:id]','[ModuleName]\Controllers\Admin[ModuleName]Controller@update');
        $this->router->post('/admin/[slug]/delete/[i:id]','[ModuleName]\Controllers\Admin[ModuleName]Controller@delete');

        // Frontend routes (wenn benötigt)
        $this->router->get('/[slug]',          '[ModuleName]\Controllers\[ModuleName]Controller@index');
        $this->router->get('/[slug]/[a:slug]', '[ModuleName]\Controllers\[ModuleName]Controller@show');

        // Admin menu
        $this->admin->addMenuItem([
            'label'    => t('nav.[slug]'),
            'url'      => '/admin/[slug]',
            'icon'     => '[icon]',
            'position' => 30,
        ]);
    }

    public function install(): void
    {
        $this->runMigrations(__DIR__ . '/migrations');
    }
}
```

**REGEL:** Alle Module folgen diesem Pattern. Keine Abweichungen.

### Controller-Klasse (Base Pattern)

```php
<?php
declare(strict_types=1);

namespace VeloCMS\Modules\[ModuleName]\Controllers;

use VeloCMS\Core\Auth;
use VeloCMS\Core\Controller;
use VeloCMS\Modules\[ModuleName]\Models\[ModuleName]Model;

class Admin[ModuleName]Controller extends Controller
{
    private [ModuleName]Model $model;

    public function __construct()
    {
        parent::__construct();
        $this->requireAuth();
        $this->model = new [ModuleName]Model();
    }

    public function index(): void
    {
        $this->view->extend('admin');
        $this->render('admin/index', ['items' => $this->model->getAll()]);
    }

    public function new(): void
    {
        $this->view->extend('admin');
        $this->render('admin/edit', ['item' => null]);
    }

    public function save(): void
    {
        Auth::verifyCsrf();
        
        // Validation
        if (empty($this->input('title', ''))) {
            $this->redirectWithError('/admin/[slug]/new', t('error.title_required'));
        }

        $id = $this->model->insert($this->collectData());
        $this->redirectWithSuccess('/admin/[slug]/edit/' . $id, t('success.saved'));
    }

    public function edit(string $id): void
    {
        $item = $this->model->getById((int) $id);
        if (!$item) {
            $this->notFound();
        }
        $this->view->extend('admin');
        $this->render('admin/edit', ['item' => $item]);
    }

    public function update(string $id): void
    {
        Auth::verifyCsrf();
        $this->model->update((int) $id, $this->collectData());
        $this->redirectWithSuccess('/admin/[slug]/edit/' . $id, t('success.updated'));
    }

    public function delete(string $id): void
    {
        Auth::verifyCsrf();
        $this->model->delete((int) $id);
        $this->redirectWithSuccess('/admin/[slug]', t('success.deleted'));
    }
}
```

**REGEL:** CSRF-Verifikation für alle POST-Requests. Immer Auth-Check.

### Model-Klasse (Base Pattern)

```php
<?php
declare(strict_types=1);

namespace VeloCMS\Modules\[ModuleName]\Models;

use VeloCMS\Core\Model;

class [ModuleName]Model extends Model
{
    protected string $table = 'velocms_[table_name]';

    public function getAll(int $limit = 20, int $offset = 0): array
    {
        $stmt = $this->db->prepare(
            "SELECT * FROM {$this->table} ORDER BY created_at DESC LIMIT :l OFFSET :o"
        );
        $stmt->bindValue(':l', $limit, \PDO::PARAM_INT);
        $stmt->bindValue(':o', $offset, \PDO::PARAM_INT);
        $stmt->execute();
        return $stmt->fetchAll(\PDO::FETCH_ASSOC);
    }

    public function getById(int $id): ?array
    {
        $stmt = $this->db->prepare("SELECT * FROM {$this->table} WHERE id = :id LIMIT 1");
        $stmt->bindValue(':id', $id, \PDO::PARAM_INT);
        $stmt->execute();
        return $stmt->fetch(\PDO::FETCH_ASSOC) ?: null;
    }

    public function insert(array $data): int
    {
        $columns = implode(', ', array_keys($data));
        $placeholders = ':' . implode(', :', array_keys($data));
        
        $stmt = $this->db->prepare(
            "INSERT INTO {$this->table} ({$columns}) VALUES ({$placeholders})"
        );
        
        foreach ($data as $key => $value) {
            $stmt->bindValue(':' . $key, $value);
        }
        
        $stmt->execute();
        return (int) $this->db->lastInsertId();
    }

    public function update(int $id, array $data): void
    {
        $set = implode(', ', array_map(fn($k) => "{$k} = :{$k}", array_keys($data)));
        $stmt = $this->db->prepare("UPDATE {$this->table} SET {$set} WHERE id = :id");
        
        $stmt->bindValue(':id', $id, \PDO::PARAM_INT);
        foreach ($data as $key => $value) {
            $stmt->bindValue(':' . $key, $value);
        }
        
        $stmt->execute();
    }

    public function delete(int $id): void
    {
        $stmt = $this->db->prepare("DELETE FROM {$this->table} WHERE id = :id");
        $stmt->bindValue(':id', $id, \PDO::PARAM_INT);
        $stmt->execute();
    }
}
```

**REGEL:** Prepared statements IMMER. Keine direkten Queries.

### Migrations (Base Pattern)

```php
<?php
declare(strict_types=1);

class CreateBlogPostsTable
{
    public function __construct(private \PDO $db) {}

    public function up(): void
    {
        $this->db->exec("
            CREATE TABLE IF NOT EXISTS velocms_blog_posts (
                id INT PRIMARY KEY AUTO_INCREMENT,
                title VARCHAR(255) NOT NULL,
                slug VARCHAR(255) UNIQUE NOT NULL,
                content LONGTEXT,
                status ENUM('draft', 'published') DEFAULT 'draft',
                created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
                deleted_at TIMESTAMP NULL
            ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci
        ");
    }
}
```

**REGEL:** Migrations sind idempotent (IF NOT EXISTS). Keine DROP TABLEs ohne Good Reason.

